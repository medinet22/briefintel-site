  </head>
  <body class="bg-dark text-white font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  
  html {
    scroll-behavior: smooth;
  }
  
  ::selection {
    background-color: #f59e0b;
    color: #0a0a0a;
  }
</style>
