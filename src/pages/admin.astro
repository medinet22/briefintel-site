---
// Dashboard admin — acceso por ?k=SECRET
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BriefIntel · Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0f172a; color: #f1f5f9; font-family: system-ui, sans-serif; min-height: 100vh; padding: 32px 24px; }
    .hidden { display: none !important; }
    #auth-error { display: none; align-items: center; justify-content: center; min-height: 80vh; text-align: center; color: rgba(255,255,255,0.4); }
    #app { max-width: 960px; margin: 0 auto; }

    /* Header */
    .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
    .logo { font-size: 22px; font-weight: 700; }
    .logo span { color: #f59e0b; }
    .logo em { color: rgba(255,255,255,0.4); font-style: normal; font-size: 15px; font-weight: 400; margin-left: 8px; }
    #last-updated { color: rgba(255,255,255,0.3); font-size: 13px; }

    /* KPIs */
    .kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
    @media(max-width:640px) { .kpis { grid-template-columns: repeat(2, 1fr); } }
    .kpi { background: #1e293b; border-radius: 12px; padding: 20px; }
    .kpi-label { color: rgba(255,255,255,0.4); font-size: 12px; margin-bottom: 8px; }
    .kpi-value { font-size: 28px; font-weight: 700; }
    .yellow { color: #f59e0b; }
    .green { color: #4ade80; }
    .orange { color: #fb923c; }

    /* Table */
    .card { background: #1e293b; border-radius: 12px; overflow: hidden; margin-bottom: 18px; }
    .card-header { padding: 16px 24px; border-bottom: 1px solid rgba(255,255,255,0.07); display: flex; justify-content: space-between; align-items: center; }
    .card-header h2 { font-size: 15px; font-weight: 600; }
    .refresh-btn { background: none; border: none; color: #f59e0b; cursor: pointer; font-size: 13px; }
    .refresh-btn:hover { text-decoration: underline; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { padding: 10px 20px; text-align: left; color: rgba(255,255,255,0.35); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid rgba(255,255,255,0.07); }
    td { padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.04); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.02); }
    .empty-row td { text-align: center; color: rgba(255,255,255,0.25); padding: 48px; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .badge-paid { background: rgba(251,146,60,0.15); color: #fb923c; }
    .badge-delivered { background: rgba(96,165,250,0.15); color: #60a5fa; }
    .badge-downloaded { background: rgba(74,222,128,0.15); color: #4ade80; }
    .badge-feedback { background: rgba(167,139,250,0.15); color: #a78bfa; }
    /* Pipeline stages */
    .pipeline-wrap { min-width: 260px; }
    .pipeline-current { font-size: 12px; color: #f59e0b; font-weight: 600; }
  </style>
</head>
<body>
  <div id="auth-error">
    <div>
      <div style="font-size:3rem;margin-bottom:12px">🔒</div>
      <p>Acceso no autorizado</p>
    </div>
  </div>

  <div id="app" style="display:none">
    <div class="header">
      <div class="logo"><span>Brief</span>Intel <em>· Admin</em></div>
      <div id="last-updated"></div>
    </div>

    <div class="kpis">
      <div class="kpi"><div class="kpi-label">Pedidos totales</div><div class="kpi-value" id="kpi-total">—</div></div>
      <div class="kpi"><div class="kpi-label">Revenue total</div><div class="kpi-value yellow" id="kpi-revenue">—</div></div>
      <div class="kpi"><div class="kpi-label">Esta semana</div><div class="kpi-value green" id="kpi-week">—</div></div>
      <div class="kpi"><div class="kpi-label">Pendientes</div><div class="kpi-value orange" id="kpi-pending">—</div></div>
    </div>

    <div class="card">
      <div class="card-header">
        <h2>Pedidos recientes</h2>
        <button class="refresh-btn" onclick="loadJobs()">↻ Actualizar</button>
      </div>
      <div style="overflow-x:auto">
        <table>
          <thead>
            <tr>
              <th>Empresa</th>
              <th>Reporte</th>
              <th>Importe</th>
              <th>Email</th>
              <th>Fecha</th>
              <th>Pipeline</th>
            </tr>
          </thead>
          <tbody id="jobs-body">
            <tr class="empty-row"><td colspan="6">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h2>Llamadas a generación (audit log)</h2>
        <button class="refresh-btn" onclick="loadGenerationLog()">↻ Actualizar</button>
      </div>
      <div style="overflow-x:auto">
        <table>
          <thead>
            <tr>
              <th>PI</th>
              <th>Empresa</th>
              <th>Web</th>
              <th>Email</th>
              <th>Estado</th>
              <th>Generado</th>
              <th>Reporte</th>
              <th>Eventos</th>
            </tr>
          </thead>
          <tbody id="gen-body">
            <tr class="empty-row"><td colspan="8">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script is:inline>
    var REPORT_LABELS = {
      'competitor-intel': 'Competitor Intel',
      'market-entry': 'Market Entry',
      'buyer-intel': 'Buyer Intel · M&A',
      'talent-market': 'Talent Market',
      'pack': 'Pack Completo'
    };

    var secret = new URLSearchParams(window.location.search).get('k');

    if (!secret) {
      document.getElementById('auth-error').style.display = 'flex';
    } else {
      document.getElementById('app').style.display = 'block';
      loadJobs();
      loadGenerationLog();
      setInterval(function(){ loadJobs(); loadGenerationLog(); }, 60000);
    }

    async function deliverTest(paymentIntent) {
      if (!paymentIntent) return;
      if (!confirm('Enviar reporte ahora en modo TEST para este pago?')) return;
      try {
        const r = await fetch('/api/admin-deliver-test', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ secret: secret, payment_intent: paymentIntent })
        });
        const d = await r.json();
        if (!r.ok) throw new Error(d.error || 'Error enviando test');
        alert('✅ Envío TEST ejecutado');
        loadJobs();
        loadGenerationLog();
      } catch (e) {
        alert('❌ ' + (e.message || 'Error enviando test'));
      }
    }

    function loadGenerationLog() {
      fetch('/api/admin-generation-log?secret=' + encodeURIComponent(secret))
        .then(function(r){ return r.json(); })
        .then(function(data){
          var rows = data.rows || [];
          if (!rows.length) {
            document.getElementById('gen-body').innerHTML = '<tr class="empty-row"><td colspan="8">Sin llamadas de generación aún</td></tr>';
            return;
          }
          document.getElementById('gen-body').innerHTML = rows.map(function(r){
            var pi = (r.payment_intent || '—');
            var piShort = pi === '—' ? '—' : pi.slice(0,16) + '…';
            var genDate = r.generated_at ? new Date(r.generated_at).toLocaleString('es-ES') : '—';
            var ev = (r.generation_events || []).slice(-3).map(function(e){ return (e.event || '?') + ' · ' + new Date(e.at).toLocaleTimeString('es-ES'); }).join('<br/>');
            var reportToken = r.report_token || '';
            var previewUrl = reportToken ? ('/api/admin-preview?secret=' + encodeURIComponent(secret) + '&token=' + encodeURIComponent(reportToken)) : '';
            var report = previewUrl ? ('<a href="' + previewUrl + '" target="_blank" style="color:#f59e0b">👁 preview</a>') : '—';
            var state = r.pipeline_state || '—';
            var stateColor = state === 'waiting_generation' ? '#fb923c' : (state === 'waiting_12h' ? '#f59e0b' : (state === 'sent' ? '#60a5fa' : (state === 'downloaded' ? '#4ade80' : (state === 'feedback' ? '#a78bfa' : 'rgba(255,255,255,0.5)'))));
            return '<tr>'
              + '<td title="' + pi + '" style="font-family:monospace;color:rgba(255,255,255,0.6)">' + piShort + '</td>'
              + '<td style="font-weight:600">' + (r.empresa_nombre||'—') + '</td>'
              + '<td style="color:rgba(255,255,255,0.55)">' + (r.empresa_web||'—') + '</td>'
              + '<td style="color:rgba(255,255,255,0.45)">' + (r.customer_email||'—') + '</td>'
              + '<td style="color:' + stateColor + ';font-weight:700">' + state + '</td>'
              + '<td style="color:rgba(255,255,255,0.5)">' + genDate + '</td>'
              + '<td>' + report + '</td>'
              + '<td style="color:rgba(255,255,255,0.45);font-size:11px;line-height:1.35">' + (ev || '—') + '</td>'
              + '</tr>';
          }).join('');
        })
        .catch(function(){
          document.getElementById('gen-body').innerHTML = '<tr class="empty-row"><td colspan="8" style="color:#f87171">Error al cargar audit log</td></tr>';
        });
    }

    function loadJobs() {
      fetch('/api/admin-jobs?secret=' + encodeURIComponent(secret))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var jobs = data.jobs || [];
          var now = Date.now();
          var weekAgo = now - 7 * 86400000;

          document.getElementById('kpi-total').textContent = jobs.length;
          document.getElementById('kpi-revenue').textContent = '€' + (jobs.reduce(function(s,j){ return s + (j.amount_total||0); }, 0) / 100).toFixed(0);
          document.getElementById('kpi-week').textContent = jobs.filter(function(j){ return new Date(j.paid_at||j.createdAt) > weekAgo; }).length;
          document.getElementById('kpi-pending').textContent = jobs.filter(function(j){ return j.status === 'paid'; }).length;
          document.getElementById('last-updated').textContent = 'Actualizado ' + new Date().toLocaleTimeString('es-ES');

          if (!jobs.length) {
            document.getElementById('jobs-body').innerHTML = '<tr class="empty-row"><td colspan="6">Sin pedidos aún</td></tr>';
            return;
          }

          jobs.sort(function(a,b){ return new Date(b.paid_at||b.createdAt) - new Date(a.paid_at||a.createdAt); });

          document.getElementById('jobs-body').innerHTML = jobs.map(function(j) {
            var date = new Date(j.paid_at || j.createdAt).toLocaleDateString('es-ES', {day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit'});
            var amount = j.amount_total ? '€' + (j.amount_total/100).toFixed(0) : '—';
            
            var stageByPipeline = {
              waiting_generation: { idx: 1, title: 'Pagado · esperando generación' },
              waiting_12h: { idx: 2, title: 'Informe generado · esperando 12h' },
              sent: { idx: 2, title: 'Informe enviado' },
              downloaded: { idx: 3, title: 'Informe descargado' },
              feedback: { idx: 4, title: 'Encuesta respondida' },
              paid: { idx: 1, title: 'Pagado' }
            };
            var st = stageByPipeline[j.pipeline_state || 'paid'] || stageByPipeline.paid;

            var btnHtml = '';
            if (j.can_send_test_now) {
              btnHtml = '<div style="margin-top:6px"><button onclick="deliverTest(\'' + (j.payment_intent || '') + '\')" style="background:#f59e0b;color:#111827;border:0;border-radius:8px;padding:6px 10px;font-size:11px;font-weight:700;cursor:pointer;">ENVIAR TEST</button></div>';
            }

            var stagesHtml = '<div class="pipeline-wrap">'
              + '<div class="pipeline-current">Etapa actual ' + st.idx + '/4: ' + st.title + '</div>'
              + btnHtml
              + '</div>';

            return '<tr>' +
              '<td style="font-weight:600">' + (j.empresa_nombre||'—') + '</td>' +
              '<td style="color:rgba(255,255,255,0.6)">' + (REPORT_LABELS[j.tipo_reporte]||j.tipo_reporte||'—') + '</td>' +
              '<td style="color:#f59e0b;font-weight:700">' + amount + '</td>' +
              '<td style="color:rgba(255,255,255,0.4);font-size:12px">' + (j.customer_email||'—') + '</td>' +
              '<td style="color:rgba(255,255,255,0.35);font-size:12px">' + date + '</td>' +
              '<td>' + stagesHtml + '</td>' +
              '</tr>';
          }).join('');
        })
        .catch(function() {
          document.getElementById('jobs-body').innerHTML = '<tr class="empty-row"><td colspan="6" style="color:#f87171">Error al cargar datos</td></tr>';
        });
    }
  </script>
</body>
</html>
