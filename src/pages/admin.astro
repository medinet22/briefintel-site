---
// Dashboard privado — acceso por query string: /admin?k=SECRET
// noindex — Google no lo indexa
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BriefIntel · Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #0f172a; color: #f1f5f9; font-family: system-ui, sans-serif; }
  </style>
</head>
<body class="min-h-screen p-8">
  <div id="auth-error" class="hidden fixed inset-0 flex items-center justify-center">
    <div class="text-center">
      <p class="text-4xl mb-4">🔒</p>
      <p class="text-white/40">Acceso no autorizado</p>
    </div>
  </div>

  <div id="app" class="hidden max-w-5xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold"><span class="text-white">Brief</span><span class="text-yellow-400">Intel</span> <span class="text-white/40 text-lg font-normal">· Admin</span></h1>
        <p class="text-white/30 text-sm mt-1">Dashboard privado · No compartir esta URL</p>
      </div>
      <div id="stats" class="text-right text-sm text-white/40"></div>
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-slate-800 rounded-xl p-4">
        <p class="text-white/40 text-xs mb-1">Pedidos totales</p>
        <p class="text-2xl font-bold text-white" id="kpi-total">—</p>
      </div>
      <div class="bg-slate-800 rounded-xl p-4">
        <p class="text-white/40 text-xs mb-1">Revenue total</p>
        <p class="text-2xl font-bold text-yellow-400" id="kpi-revenue">—</p>
      </div>
      <div class="bg-slate-800 rounded-xl p-4">
        <p class="text-white/40 text-xs mb-1">Esta semana</p>
        <p class="text-2xl font-bold text-green-400" id="kpi-week">—</p>
      </div>
      <div class="bg-slate-800 rounded-xl p-4">
        <p class="text-white/40 text-xs mb-1">Pendientes</p>
        <p class="text-2xl font-bold text-orange-400" id="kpi-pending">—</p>
      </div>
    </div>

    <!-- Tabla de pedidos -->
    <div class="bg-slate-800 rounded-xl overflow-hidden">
      <div class="px-6 py-4 border-b border-white/10 flex items-center justify-between">
        <h2 class="font-semibold text-white">Pedidos recientes</h2>
        <button onclick="loadJobs()" class="text-xs text-yellow-400 hover:underline">↻ Actualizar</button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-white/40 text-xs border-b border-white/10">
              <th class="px-6 py-3 text-left">Empresa</th>
              <th class="px-6 py-3 text-left">Reporte</th>
              <th class="px-6 py-3 text-left">Importe</th>
              <th class="px-6 py-3 text-left">Email</th>
              <th class="px-6 py-3 text-left">Fecha</th>
              <th class="px-6 py-3 text-left">Estado</th>
            </tr>
          </thead>
          <tbody id="jobs-body">
            <tr><td colspan="6" class="px-6 py-8 text-center text-white/30">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    const REPORT_LABELS = {
      'competitor-intel': 'Competitor Intel',
      'market-entry': 'Market Entry',
      'buyer-intel': 'Buyer Intel · M&A',
      'talent-market': 'Talent Market',
      'pack': 'Pack Completo',
    };

    const params = new URLSearchParams(window.location.search);
    const secret = params.get('k');

    if (!secret) {
      document.getElementById('auth-error').classList.remove('hidden');
    } else {
      document.getElementById('app').classList.remove('hidden');
      loadJobs();
      setInterval(loadJobs, 60000);
    }

    async function loadJobs() {
      try {
        const res = await fetch(`/api/admin-jobs?secret=${encodeURIComponent(secret)}`);
        if (!res.ok) {
          document.getElementById('jobs-body').innerHTML = '<tr><td colspan="6" class="px-6 py-8 text-center text-red-400">Acceso denegado</td></tr>';
          return;
        }
        const { jobs } = await res.json();

        document.getElementById('kpi-total').textContent = jobs.length;
        document.getElementById('kpi-revenue').textContent = '€' + (jobs.reduce((s, j) => s + (j.amount_total || 0), 0) / 100).toFixed(0);
        document.getElementById('kpi-week').textContent = jobs.filter(j => new Date(j.paid_at || j.created_at) > new Date(Date.now() - 7 * 86400000)).length;
        document.getElementById('kpi-pending').textContent = jobs.filter(j => j.status === 'paid').length;
        document.getElementById('stats').textContent = 'Actualizado ' + new Date().toLocaleTimeString('es-ES');

        if (!jobs.length) {
          document.getElementById('jobs-body').innerHTML = '<tr><td colspan="6" class="px-6 py-8 text-center text-white/30">Sin pedidos aún</td></tr>';
          return;
        }

        document.getElementById('jobs-body').innerHTML = jobs.map(j => {
          const date = new Date(j.paid_at || j.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
          const statusColor = j.status === 'paid' ? 'text-orange-400' : j.status === 'completed' ? 'text-green-400' : 'text-white/40';
          const statusLabel = j.status === 'paid' ? 'Pendiente' : j.status === 'completed' ? 'Entregado' : j.status || '—';
          const amount = j.amount_total ? '€' + (j.amount_total / 100).toFixed(0) : '—';
          return `<tr class="border-b border-white/5 hover:bg-slate-700/30">
            <td class="px-6 py-4 font-medium text-white">${j.empresa_nombre || '—'}</td>
            <td class="px-6 py-4 text-white/70">${REPORT_LABELS[j.tipo_reporte] || j.tipo_reporte || '—'}</td>
            <td class="px-6 py-4 text-yellow-400 font-semibold">${amount}</td>
            <td class="px-6 py-4 text-white/50 text-xs">${j.customer_email || '—'}</td>
            <td class="px-6 py-4 text-white/40 text-xs">${date}</td>
            <td class="px-6 py-4 font-medium ${statusColor}">${statusLabel}</td>
          </tr>`;
        }).join('');
      } catch(e) {
        document.getElementById('jobs-body').innerHTML = `<tr><td colspan="6" class="px-6 py-8 text-center text-red-400">Error: ${e.message}</td></tr>`;
      }
    }
  </script>
</body>
</html>
