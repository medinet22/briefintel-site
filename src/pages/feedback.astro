---
// Feedback page — token leído de ?t= query param
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>¿Qué te pareció? — BriefIntel</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0f172a; color: #f1f5f9; font-family: system-ui, -apple-system, sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
    .card { background: #1e293b; border-radius: 16px; padding: 36px; max-width: 480px; width: 100%; }
    .logo { color: #f59e0b; font-size: 22px; font-weight: 700; margin-bottom: 4px; }
    .logo span { color: #f1f5f9; }
    .sub { color: #475569; font-size: 12px; margin-bottom: 28px; }
    h2 { font-size: 20px; margin-bottom: 6px; }
    .hint { color: rgba(255,255,255,0.4); font-size: 13px; margin-bottom: 32px; }
    .q { font-weight: 600; margin-bottom: 14px; }
    .section { margin-bottom: 28px; }

    /* Stars */
    .stars { display: flex; gap: 8px; margin-bottom: 8px; }
    .star { font-size: 36px; cursor: pointer; opacity: 0.35; transition: opacity 0.15s, transform 0.1s; user-select: none; }
    .star:hover { opacity: 0.7; transform: scale(1.1); }
    .star.on { opacity: 1; transform: scale(1.05); }
    #star-label { color: rgba(255,255,255,0.35); font-size: 13px; min-height: 18px; }

    /* Utility buttons */
    .opts { display: flex; flex-wrap: wrap; gap: 10px; }
    .opt { background: transparent; border: 1px solid rgba(255,255,255,0.18); color: rgba(255,255,255,0.6); padding: 9px 16px; border-radius: 8px; font-size: 14px; cursor: pointer; transition: border-color 0.15s, color 0.15s; }
    .opt:hover { border-color: rgba(245,158,11,0.5); color: rgba(245,158,11,0.8); }
    .opt.on { border-color: #f59e0b; color: #f59e0b; background: rgba(245,158,11,0.08); }

    /* Textarea */
    textarea { width: 100%; background: #0f172a; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 12px 14px; color: rgba(255,255,255,0.8); font-size: 14px; resize: none; outline: none; transition: border-color 0.15s; font-family: inherit; }
    textarea:focus { border-color: rgba(245,158,11,0.4); }

    /* Button */
    #sbtn { width: 100%; background: #f59e0b; color: #0f172a; font-weight: 700; font-size: 16px; padding: 14px; border: none; border-radius: 10px; cursor: pointer; margin-top: 8px; transition: background 0.15s; }
    #sbtn:hover { background: #fbbf24; }
    #sbtn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* Done state */
    #done { display: none; text-align: center; }
    #done .emoji { font-size: 52px; margin-bottom: 16px; }
    #done h2 { margin-bottom: 8px; }
    #done p { color: rgba(255,255,255,0.4); font-size: 14px; margin-bottom: 24px; }
    #done a { color: #f59e0b; font-size: 14px; text-decoration: none; }
    #done a:hover { text-decoration: underline; }

    hr { border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 28px 0; }
  </style>
</head>
<body>
  <div class="card">
    <!-- Formulario -->
    <div id="form">
      <div class="logo"><span>Brief</span>Intel</div>
      <div class="sub">Intelligence Reports</div>
      <h2>¿Qué te pareció tu reporte? 📊</h2>
      <p class="hint">3 preguntas · 1 minuto · Nos ayuda a mejorar</p>

      <!-- Estrellas -->
      <div class="section">
        <div class="q">1. ¿Cómo valorarías el reporte?</div>
        <div class="stars">
          <span class="star" data-v="1">⭐</span>
          <span class="star" data-v="2">⭐</span>
          <span class="star" data-v="3">⭐</span>
          <span class="star" data-v="4">⭐</span>
          <span class="star" data-v="5">⭐</span>
        </div>
        <div id="star-label">Selecciona una valoración</div>
      </div>

      <!-- Utilidad -->
      <div class="section">
        <div class="q">2. ¿Encontraste información accionable?</div>
        <div class="opts">
          <button class="opt" data-u="Sí, muy útil">Sí, muy útil</button>
          <button class="opt" data-u="Bastante útil">Bastante útil</button>
          <button class="opt" data-u="Algo útil">Algo útil</button>
          <button class="opt" data-u="Poco útil">Poco útil</button>
        </div>
      </div>

      <!-- Comentario -->
      <div class="section">
        <div class="q">3. ¿Qué mejorarías? <span style="font-weight:400;color:rgba(255,255,255,0.3)">(opcional)</span></div>
        <textarea id="comment" rows="3" placeholder="Tu opinión nos ayuda a mejorar cada reporte..."></textarea>
      </div>

      <button id="sbtn">Enviar valoración</button>
    </div>

    <!-- Gracias -->
    <div id="done">
      <div class="emoji">🙌</div>
      <h2>¡Gracias por tu feedback!</h2>
      <p>Tu opinión mejora cada reporte que hacemos.</p>
      <a href="https://getbriefintel.com">← Volver a BriefIntel</a>
    </div>
  </div>

  <script is:inline>
    var rating = 0;
    var utility = '';
    var token = new URLSearchParams(window.location.search).get('t') || '';

    var starLabels = ['','Muy malo 😕','Malo','Normal','Bueno 👍','Excelente ⭐'];

    // Stars
    document.querySelectorAll('.star').forEach(function(s) {
      s.addEventListener('click', function() {
        rating = parseInt(s.getAttribute('data-v'));
        document.querySelectorAll('.star').forEach(function(x, i) {
          x.classList.toggle('on', i < rating);
        });
        document.getElementById('star-label').textContent = starLabels[rating];
      });
    });

    // Utility buttons
    document.querySelectorAll('.opt').forEach(function(b) {
      b.addEventListener('click', function() {
        utility = b.getAttribute('data-u');
        document.querySelectorAll('.opt').forEach(function(x) {
          x.classList.toggle('on', x === b);
        });
      });
    });

    // Submit
    document.getElementById('sbtn').addEventListener('click', function() {
      if (!rating) { alert('Por favor selecciona una valoración (estrellas)'); return; }
      var btn = document.getElementById('sbtn');
      btn.disabled = true;
      btn.textContent = 'Enviando...';

      var comment = document.getElementById('comment').value;

      fetch('/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: token, rating: rating, utility: utility, comment: comment })
      }).catch(function(){}).finally(function() {
        document.getElementById('form').style.display = 'none';
        document.getElementById('done').style.display = 'block';
      });
    });
  </script>
</body>
</html>
