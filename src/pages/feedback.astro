---
// Feedback estático — el token se lee del path client-side
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>¿Qué te pareció tu reporte? — BriefIntel</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen flex items-center justify-center px-6 py-12" style="background:#0f172a;color:#f1f5f9;font-family:system-ui,sans-serif">
  <div class="max-w-lg w-full mx-auto">
    <div class="text-center mb-10">
      <h1 class="text-2xl font-bold mb-1"><span style="color:#fff">Brief</span><span style="color:#f59e0b">Intel</span></h1>
      <p style="color:rgba(255,255,255,0.4)" class="text-sm">Valoración de tu reporte</p>
    </div>
    <div id="form-container" class="rounded-2xl p-8" style="background:#1e293b">
      <h2 class="text-xl font-semibold mb-2">¿Qué te pareció? 📊</h2>
      <p style="color:rgba(255,255,255,0.4)" class="text-sm mb-8">1 minuto · 3 preguntas</p>

      <div class="mb-8">
        <p class="font-medium mb-4">1. ¿Cómo valorarías el reporte?</p>
        <div class="flex gap-2" id="stars">
          <span class="star" data-v="1" style="cursor:pointer;font-size:2rem">⭐</span>
          <span class="star" data-v="2" style="cursor:pointer;font-size:2rem">⭐</span>
          <span class="star" data-v="3" style="cursor:pointer;font-size:2rem">⭐</span>
          <span class="star" data-v="4" style="cursor:pointer;font-size:2rem">⭐</span>
          <span class="star" data-v="5" style="cursor:pointer;font-size:2rem">⭐</span>
        </div>
        <p style="color:rgba(255,255,255,0.3)" class="text-xs mt-2" id="star-label">Selecciona una valoración</p>
      </div>

      <div class="mb-8">
        <p class="font-medium mb-3">2. ¿Encontraste información accionable?</p>
        <div class="flex gap-3 flex-wrap">
          <button onclick="selectU('Sí, muy útil')" class="ubtn px-4 py-2 rounded-lg text-sm" style="border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.6)">Sí, muy útil</button>
          <button onclick="selectU('Bastante útil')" class="ubtn px-4 py-2 rounded-lg text-sm" style="border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.6)">Bastante útil</button>
          <button onclick="selectU('Algo útil')" class="ubtn px-4 py-2 rounded-lg text-sm" style="border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.6)">Algo útil</button>
          <button onclick="selectU('Poco útil')" class="ubtn px-4 py-2 rounded-lg text-sm" style="border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.6)">Poco útil</button>
        </div>
      </div>

      <div class="mb-8">
        <p class="font-medium mb-3">3. ¿Qué mejorarías? <span style="color:rgba(255,255,255,0.3);font-weight:400">(opcional)</span></p>
        <textarea id="comment" rows="3" placeholder="Tu opinión nos ayuda a mejorar..."
          class="w-full rounded-lg px-4 py-3 text-sm resize-none focus:outline-none"
          style="background:#0f172a;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.8)"></textarea>
      </div>

      <button onclick="submit()" id="sbtn" class="w-full font-bold py-3 rounded-xl text-base"
        style="background:#f59e0b;color:#0f172a">Enviar valoración</button>
    </div>

    <div id="done" class="hidden text-center rounded-2xl p-8" style="background:#1e293b">
      <p class="text-4xl mb-4">🙌</p>
      <h2 class="text-xl font-semibold mb-2">¡Gracias!</h2>
      <p style="color:rgba(255,255,255,0.5)" class="text-sm">Tu opinión mejora cada reporte.</p>
      <a href="https://getbriefintel.com" style="color:#f59e0b" class="inline-block mt-6 text-sm hover:underline">← Volver a BriefIntel</a>
    </div>
  </div>
  <script>
    const token = new URLSearchParams(window.location.search).get('t') || window.location.pathname.split('/').filter(Boolean).pop();
    let rating = 0, utility = '';
    document.querySelectorAll('.star').forEach(s => {
      s.addEventListener('click', () => {
        rating = +s.dataset.v;
        document.querySelectorAll('.star').forEach((x,i) => x.style.opacity = i < rating ? '1' : '0.4');
        document.getElementById('star-label').textContent = ['','Muy malo','Malo','Normal','Bueno','Excelente'][rating];
      });
    });
    function selectU(v) {
      utility = v;
      document.querySelectorAll('.ubtn').forEach(b => {
        const on = b.textContent === v;
        b.style.borderColor = on ? '#f59e0b' : 'rgba(255,255,255,0.2)';
        b.style.color = on ? '#f59e0b' : 'rgba(255,255,255,0.6)';
      });
    }
    async function submit() {
      if (!rating) { alert('Selecciona una valoración'); return; }
      document.getElementById('sbtn').textContent = 'Enviando...';
      document.getElementById('sbtn').disabled = true;
      const comment = document.getElementById('comment').value;
      try {
        await fetch('/api/feedback', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ token, rating, utility, comment })
        });
      } catch(e) {}
      document.getElementById('form-container').classList.add('hidden');
      document.getElementById('done').classList.remove('hidden');
    }
  </script>
</body>
</html>
