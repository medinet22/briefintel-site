---
import Layout from '../layouts/Layout.astro';

const reportTypes = [
  { value: 'competitor-intel', label: 'Competitor Intel — €35' },
  { value: 'market-entry', label: 'Market Entry Brief — €49' },
  { value: 'buyer-intel', label: 'Buyer Intel M&A — €59' },
  { value: 'talent-market', label: 'Talent Market Intel — €19' },
  { value: 'pack', label: 'Pack Completo (4 reportes) — €119' },
];

const preTipo = Astro.url.searchParams.get('tipo') || '';
---

<Layout title="Brief de tu reporte — BriefIntel">
  <div class="min-h-screen bg-dark pt-8 pb-24 px-6">
    <div class="max-w-2xl mx-auto">

      <div class="text-center mb-12 pt-8">
        <a href="/" class="inline-block mb-8">
          <span class="text-accent font-black text-2xl tracking-tight">BRIEF<span class="text-white">INTEL</span></span>
        </a>
        <h1 class="text-3xl md:text-4xl font-bold mb-4">Completa tu brief (5 min)</h1>
        <p class="text-white/60 text-lg max-w-lg mx-auto">Primero guardamos tu brief, luego te llevamos al pago seguro con Stripe.</p>
      </div>

      <form id="briefForm" novalidate class="space-y-6">
        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6">
          <label class="block text-sm font-semibold text-accent uppercase tracking-wider mb-3">Tipo de reporte</label>
          <select id="tipo_reporte" name="tipo_reporte" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm">
            <option value="" disabled selected class="bg-dark">Selecciona el tipo de reporte</option>
            {reportTypes.map(r => (<option value={r.value} class="bg-dark">{r.label}</option>))}
          </select>
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 space-y-4">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">Tu empresa</h3>
          <input type="text" id="empresa_nombre" name="empresa_nombre" required placeholder="Nombre de tu empresa" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <p id="err_empresa_nombre" class="text-red-400 text-xs mt-1 hidden">Escribe el nombre de tu empresa</p>
          <input type="text" id="empresa_web" name="empresa_web" required placeholder="tuempresa.com" autocomplete="url" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <p id="err_empresa_web" class="text-red-400 text-xs mt-1 hidden">Introduce una web válida (ej: tuempresa.com)</p>
          <div class="grid grid-cols-2 gap-4">
            <input type="text" id="sector" name="sector" required placeholder="Sector (ej: SaaS, Retail, Fintech)" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
            <select name="tamano" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm">
              <option value="1" class="bg-dark">Solo yo</option>
              <option value="2-10" class="bg-dark">2-10 personas</option>
              <option value="11-50" selected class="bg-dark">11-50 personas</option>
              <option value="50+" class="bg-dark">Más de 50</option>
            </select>
          </div>
          <p id="err_sector" class="text-red-400 text-xs mt-1 hidden">Indica el sector de tu empresa</p>
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 space-y-4">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">Preguntas para afinar el reporte</h3>
          <p class="text-xs text-white/50">Todas las preguntas de este bloque son opcionales. Si respondes alguna, el informe sale mucho más preciso y accionable.</p>

          <div class="space-y-2">
            <label class="block text-xs text-white/60">Foco principal (opcional)</label>
            <textarea id="pregunta_1" name="pregunta_1" rows="3" placeholder="Ejemplo: ¿Qué preguntas quieres responder con este reporte?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
          </div>

          <div class="space-y-2">
            <label class="block text-xs text-white/60">Decisión que quieres tomar <span class="text-white/30">(opcional — cuanto más concreto, mejor el reporte)</span></label>
            <textarea id="pregunta_2" rows="3" placeholder="Ej: Decidir si expandirme a Barcelona este año. / Saber si vale la pena salir a Europa ahora." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
          </div>

          <div class="space-y-2">
            <label class="block text-xs text-white/60">Preguntas que quieres responder (opcional)</label>
            <textarea id="pregunta_3" rows="3" placeholder="Ejemplo: ¿Qué preguntas quieres responder con este informe?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
          </div>

          <input type="hidden" name="decision" id="decision_hidden" />
          <input type="hidden" name="preguntas_clave" id="preguntas_clave" />
        </div>

        <!-- Archivos de apoyo: oculto hasta implementar upload real -->
        <input type="hidden" name="adjuntos_nombres" id="adjuntos_nombres" />

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">Email de entrega</h3>
          <p class="text-xs text-white/50 mb-3">Te enviaremos confirmación y el estado de tu pedido a este correo.</p>
          <input type="email" id="email" name="email" required placeholder="tu@empresa.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <p id="err_email" class="text-red-400 text-xs mt-1 hidden">Introduce un email válido</p>
          <input type="hidden" name="sujeto_nombre" id="sujeto_nombre" />
          <input type="hidden" name="sujeto_web" value="" />
          <label class="mt-3 flex items-start gap-2 text-xs text-white/60">
            <input type="checkbox" id="consent" name="consent" required class="mt-0.5" />
            Acepto recibir comunicaciones sobre mi brief y reporte.
          </label>
          <p id="err_consent" class="text-red-400 text-xs mt-1 hidden">Debes aceptar las comunicaciones para continuar</p>
        </div>

        <button id="submitBtn" type="submit" class="w-full bg-accent hover:bg-accent/90 text-dark py-4 rounded-xl text-lg font-bold">Guardar brief y continuar al pago</button>
        <p id="errorMsg" class="text-red-300 text-sm hidden"></p>
      </form>
    </div>
  </div>

  <script is:inline>
    const preTipo = new URLSearchParams(location.search).get('tipo');
    const tipoSelect = document.getElementById('tipo_reporte');
    const pregunta1 = document.getElementById('pregunta_1');
    const pregunta2 = document.getElementById('pregunta_2');
    const pregunta3 = document.getElementById('pregunta_3');
    const dropzone = document.getElementById('dropzone');
    const adjuntos = document.getElementById('adjuntos');
    const adjuntosNombres = document.getElementById('adjuntos_nombres');
    const adjuntosInfo = document.getElementById('adjuntosInfo');
    const decisionHidden = document.getElementById('decision_hidden');
    const preguntasClave = document.getElementById('preguntas_clave');
    const sujetoNombre = document.getElementById('sujeto_nombre');

    const placeholderByType = {
      'competitor-intel': {
        q1: 'Ejemplo: ¿Qué competidores te preocupan más y por qué? ', 
        q2: 'Ejemplo: ¿Quieres decidir cómo defender cuota o cómo atacar un segmento específico?',
        q3: 'Ejemplo: ¿Qué preguntas quieres responder: precios, canales, mensaje, retención?'
      },
      'market-entry': {
        q1: 'Ejemplo: ¿Qué mercado/segmento te interesa priorizar primero?',
        q2: 'Ejemplo: ¿Quieres decidir si entrar ahora, cómo entrar o con qué oferta?',
        q3: 'Ejemplo: ¿Qué preguntas quieres responder: tamaño real, barreras, demanda, timing?'
      },
      'buyer-intel': {
        q1: 'Ejemplo: ¿Qué compradores potenciales ya tienes mapeados y cuáles quieres priorizar en el análisis?',
        q2: 'Ejemplo: ¿Quieres decidir a quién acercarte primero y en qué condiciones?',
        q3: 'Ejemplo: ¿Qué preguntas quieres responder: encaje, valoración, probabilidad de cierre?'
      },
      'talent-market': {
        q1: 'Ejemplo: ¿Qué perfiles son más críticos para tu siguiente etapa?',
        q2: 'Ejemplo: ¿Quieres decidir orden de contratación, seniority o mix España/LATAM?',
        q3: 'Ejemplo: ¿Qué preguntas quieres responder: salarios, canales, tiempos de cierre, riesgos?'
      },
      'pack': {
        q1: 'Ejemplo: ¿Qué frente estratégico te urge más: competencia, mercado, buyer o talento?',
        q2: 'Ejemplo: ¿Qué decisiones quieres tomar al recibir el pack completo?',
        q3: 'Ejemplo: ¿Qué preguntas clave quieres responder en cada uno de los 4 reportes?'
      }
    };

    const setDynamicQuestionPlaceholder = () => {
      const tipo = tipoSelect?.value || '';
      const p = placeholderByType[tipo] || placeholderByType['pack'];
      if (pregunta1) pregunta1.placeholder = p.q1;
      if (pregunta2) pregunta2.placeholder = p.q2;
      if (pregunta3) pregunta3.placeholder = p.q3;
    };

    if (preTipo) tipoSelect.value = preTipo;
    setDynamicQuestionPlaceholder();
    tipoSelect?.addEventListener('change', setDynamicQuestionPlaceholder);

    const syncAdjuntos = (files) => {
      const list = Array.from(files || []).slice(0, 3);
      const dt = new DataTransfer();
      list.forEach(f => dt.items.add(f));
      if (adjuntos) adjuntos.files = dt.files;
      const names = list.map(f => f.name);
      if (adjuntosNombres) adjuntosNombres.value = names.join(' | ');
      if (adjuntosInfo) {
        adjuntosInfo.textContent = names.length
          ? `Archivos seleccionados: ${names.join(', ')}`
          : 'Los archivos se registran para contexto del análisis.';
      }
    };

    adjuntos?.addEventListener('change', () => syncAdjuntos(adjuntos.files));

    dropzone?.addEventListener('click', () => adjuntos?.click());
    dropzone?.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.classList.add('border-accent/70');
    });
    dropzone?.addEventListener('dragleave', () => dropzone.classList.remove('border-accent/70'));
    dropzone?.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-accent/70');
      syncAdjuntos(e.dataTransfer?.files || []);
    });

    const form = document.getElementById('briefForm');
    const btn = document.getElementById('submitBtn');
    const err = document.getElementById('errorMsg');

    // Field-level error helpers
    function showFieldError(id, show) {
      const el = document.getElementById('err_' + id);
      if (el) el.classList.toggle('hidden', !show);
      const input = document.getElementById(id);
      if (input) {
        input.classList.toggle('border-red-500', show);
        input.classList.toggle('border-white/10', !show);
      }
    }
    function clearAllErrors() {
      ['empresa_nombre','empresa_web','sector','email','consent'].forEach(id => showFieldError(id, false));
      err.classList.add('hidden');
    }
    function isValidDomain(val) {
      const v = val.trim();
      if (!v) return false;
      // Accept: domain.com, https://domain.com, www.domain.com etc.
      return /^(https?:\/\/)?[\w.-]+\.[a-z]{2,}(\/.*)?$/i.test(v);
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearAllErrors();

      // Client-side field validation with per-field errors
      let hasError = false;
      const tipoVal = tipoSelect?.value || '';
      if (!tipoVal) { err.textContent = 'Selecciona el tipo de reporte'; err.classList.remove('hidden'); hasError = true; }
      const empresaNombre = document.getElementById('empresa_nombre')?.value?.trim();
      if (!empresaNombre) { showFieldError('empresa_nombre', true); hasError = true; }
      const empresaWeb = document.getElementById('empresa_web')?.value?.trim();
      if (!empresaWeb || !isValidDomain(empresaWeb)) { showFieldError('empresa_web', true); hasError = true; }
      const sectorVal = document.getElementById('sector')?.value?.trim();
      if (!sectorVal) { showFieldError('sector', true); hasError = true; }
      const emailVal = document.getElementById('email')?.value?.trim();
      if (!emailVal || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) { showFieldError('email', true); hasError = true; }
      const consentVal = document.getElementById('consent')?.checked;
      if (!consentVal) { showFieldError('consent', true); hasError = true; }
      if (hasError) {
        // Scroll to first visible error
        const firstErr = form.querySelector('[id^="err_"]:not(.hidden)') || err;
        firstErr?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      const old = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Guardando brief...';

      const tipo = tipoSelect?.value || '';
      const p1 = (pregunta1?.value || '').trim();
      const p2 = (pregunta2?.value || '').trim();
      const p3 = (pregunta3?.value || '').trim();
      const adj = (adjuntosNombres?.value || '').trim();

      const mergedParts = [
        p1 ? `Foco principal (opcional): ${p1}` : '',
        p2 ? `Decisión(es) a tomar (opcional): ${p2}` : '',
        p3 ? `Preguntas a responder (opcional): ${p3}` : '',
        adj ? `Archivos de apoyo: ${adj}` : ''
      ].filter(Boolean);

      if (preguntasClave) preguntasClave.value = mergedParts.join('\n');
      if (decisionHidden) {
        decisionHidden.value = p2 || p1 || `Definir plan de acción para ${tipo || 'el informe solicitado'}`;
      }

      const sujetoByTipo = {
        'competitor-intel': 'Análisis competitivo',
        'market-entry': 'Análisis de entrada a mercado',
        'buyer-intel': 'Análisis de compradores potenciales',
        'talent-market': 'Análisis de mercado de talento',
        'pack': 'Análisis estratégico integral'
      };
      if (sujetoNombre) sujetoNombre.value = sujetoByTipo[tipo] || 'Análisis estratégico';

      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch('/api/brief', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error || 'No se pudo guardar el brief');
        if (json.checkout_url) {
          btn.textContent = 'Redirigiendo a pago...';
          window.location.href = json.checkout_url;
          return;
        }
        window.location.href = json.next || '/gracias';
      } catch (e2) {
        err.textContent = e2.message || 'Error al enviar brief';
        err.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = old;
      }
    });
  </script>
</Layout>

<style>select option { background:#111; color:white; }</style>
