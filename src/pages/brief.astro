---
import Layout from '../layouts/Layout.astro';

const reportTypes = [
  { value: 'competitor-intel', label: 'Competitor Intel — €35' },
  { value: 'market-entry', label: 'Market Entry Brief — €49' },
  { value: 'buyer-intel', label: 'Buyer Intel M&A — €59' },
  { value: 'talent-market', label: 'Talent Market Intel — €19' },
  { value: 'pack', label: 'Pack Completo (4 reportes) — €119' },
];

const preTipo = Astro.url.searchParams.get('tipo') || '';
---

<Layout title="Brief de tu reporte — BriefIntel">
  <div class="min-h-screen bg-dark pt-8 pb-24 px-6">
    <div class="max-w-2xl mx-auto">

      <div class="text-center mb-12 pt-8">
        <a href="/" class="inline-block mb-8">
          <span class="text-accent font-black text-2xl tracking-tight">BRIEF<span class="text-white">INTEL</span></span>
        </a>
        <h1 class="text-3xl md:text-4xl font-bold mb-4">Completa tu brief (5 min)</h1>
        <p class="text-white/60 text-lg max-w-lg mx-auto">Primero guardamos tu brief, luego te llevamos al pago seguro con Stripe.</p>
      </div>

      <form id="briefForm" class="space-y-6">
        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6">
          <label class="block text-sm font-semibold text-accent uppercase tracking-wider mb-3">Tipo de reporte</label>
          <select id="tipo_reporte" name="tipo_reporte" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm">
            <option value="" disabled selected class="bg-dark">Selecciona el tipo de reporte</option>
            {reportTypes.map(r => (<option value={r.value} class="bg-dark">{r.label}</option>))}
          </select>
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 space-y-4">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">Tu empresa</h3>
          <input type="text" name="empresa_nombre" required placeholder="Nombre de tu empresa" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <input type="url" name="empresa_web" required placeholder="https://tuempresa.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <div class="grid grid-cols-2 gap-4">
            <input type="text" name="sector" required placeholder="Sector" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
            <select name="tamano" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm">
              <option value="1" class="bg-dark">Solo yo</option>
              <option value="2-10" class="bg-dark">2-10 personas</option>
              <option value="11-50" selected class="bg-dark">11-50 personas</option>
              <option value="50+" class="bg-dark">Más de 50</option>
            </select>
          </div>
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 space-y-4">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">Sujeto del análisis</h3>
          <input type="text" name="sujeto_nombre" required placeholder="Competidor, mercado, buyer, etc." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <input type="text" name="sujeto_web" placeholder="Web/LinkedIn (opcional)" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 space-y-5">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">Decisión y enfoque del análisis</h3>
          <textarea name="decision" required rows="3" placeholder="¿Qué decisión necesitas tomar con este reporte?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>

          <div class="space-y-2">
            <label id="pregunta_principal_label" for="pregunta_1" class="block text-xs font-semibold text-white/70 uppercase tracking-wider">
              Pregunta principal del reporte
            </label>
            <textarea id="pregunta_1" name="pregunta_1" rows="3" placeholder="Esta pregunta cambia según el tipo de reporte" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
          </div>

          <div id="pack_questions" class="hidden space-y-3">
            <p class="text-xs font-semibold text-white/70 uppercase tracking-wider">Preguntas clave del pack completo</p>
            <textarea id="pack_q_competitor" rows="2" placeholder="Competitor Intel: ¿qué competidores (uno o varios) quieres analizar?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
            <textarea id="pack_q_market" rows="2" placeholder="Market Entry: ¿a qué mercado(s) quieres entrar y con qué producto/servicio?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
            <textarea id="pack_q_buyer" rows="2" placeholder="Buyer Intel: ¿qué buyer(s) o tipo de comprador potencial quieres evaluar?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
            <textarea id="pack_q_talent" rows="2" placeholder="Talent Intel: ¿qué perfiles clave estás buscando en la organización?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
          </div>

          <div class="space-y-2">
            <label for="contexto_opcional" class="block text-xs font-semibold text-white/70 uppercase tracking-wider">
              Contexto adicional (opcional)
            </label>
            <textarea id="contexto_opcional" rows="4" placeholder="Añade aquí cualquier detalle que nos ayude a afinar más el reporte: contexto interno, hipótesis, restricciones, países prioritarios, timing, etc." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
          </div>

          <input type="hidden" name="preguntas_clave" id="preguntas_clave" />
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6">
          <input type="email" name="email" required placeholder="tu@empresa.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <label class="mt-3 flex items-start gap-2 text-xs text-white/60">
            <input type="checkbox" name="consent" required class="mt-0.5" />
            Acepto recibir comunicaciones sobre mi brief y reporte.
          </label>
        </div>

        <button id="submitBtn" type="submit" class="w-full bg-accent hover:bg-accent/90 text-dark py-4 rounded-xl text-lg font-bold">Guardar brief y continuar al pago</button>
        <p id="errorMsg" class="text-red-300 text-sm hidden"></p>
      </form>
    </div>
  </div>

  <script is:inline>
    const preTipo = new URLSearchParams(location.search).get('tipo');
    const tipoSelect = document.getElementById('tipo_reporte');
    const pregunta1 = document.getElementById('pregunta_1');
    const preguntaPrincipalLabel = document.getElementById('pregunta_principal_label');
    const packQuestions = document.getElementById('pack_questions');
    const packQCompetitor = document.getElementById('pack_q_competitor');
    const packQMarket = document.getElementById('pack_q_market');
    const packQBuyer = document.getElementById('pack_q_buyer');
    const packQTalent = document.getElementById('pack_q_talent');
    const contextoOpcional = document.getElementById('contexto_opcional');
    const preguntasClave = document.getElementById('preguntas_clave');

    const firstQuestionByReport = {
      'competitor-intel': 'Competitor Intel: ¿qué competidor(es) quieres analizar y por qué te preocupa cada uno?',
      'market-entry': 'Market Entry: ¿en qué mercado(s) quieres entrar y con qué producto/servicio?',
      'buyer-intel': 'Buyer Intel: ¿qué buyer(s) o tipo de comprador potencial quieres evaluar?',
      'talent-market': 'Talent Intel: ¿qué perfiles más críticos estás buscando en la organización?',
      'pack': 'Pack completo: resume la decisión principal que quieres resolver con los 4 reportes.'
    };

    const setDynamicQuestionPlaceholder = () => {
      const tipo = tipoSelect?.value || '';
      const dynamic = firstQuestionByReport[tipo] || 'Esta pregunta cambia según el tipo de reporte';
      if (pregunta1) pregunta1.placeholder = dynamic;

      const isPack = tipo === 'pack';
      if (packQuestions) packQuestions.classList.toggle('hidden', !isPack);
      if (preguntaPrincipalLabel) {
        preguntaPrincipalLabel.textContent = isPack
          ? 'Pregunta de contexto general del pack'
          : 'Pregunta principal del reporte';
      }
    };

    if (preTipo) tipoSelect.value = preTipo;
    setDynamicQuestionPlaceholder();
    tipoSelect?.addEventListener('change', setDynamicQuestionPlaceholder);

    const form = document.getElementById('briefForm');
    const btn = document.getElementById('submitBtn');
    const err = document.getElementById('errorMsg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      err.classList.add('hidden');
      const old = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Guardando brief...';

      const tipo = tipoSelect?.value || '';
      const p1 = (pregunta1?.value || '').trim();
      const extra = (contextoOpcional?.value || '').trim();

      const mergedParts = [];
      if (p1) mergedParts.push(`Contexto principal: ${p1}`);

      if (tipo === 'pack') {
        const packBlocks = [
          ['Competitor Intel', (packQCompetitor?.value || '').trim()],
          ['Market Entry', (packQMarket?.value || '').trim()],
          ['Buyer Intel', (packQBuyer?.value || '').trim()],
          ['Talent Intel', (packQTalent?.value || '').trim()],
        ].filter(([, v]) => v);

        packBlocks.forEach(([label, value], i) => {
          mergedParts.push(`${i + 1}. ${label}: ${value}`);
        });
      }

      if (extra) mergedParts.push(`Contexto adicional (opcional): ${extra}`);

      if (preguntasClave) preguntasClave.value = mergedParts.join('\n');

      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch('/api/brief', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error || 'No se pudo guardar el brief');
        if (json.checkout_url) {
          btn.textContent = 'Redirigiendo a pago...';
          window.location.href = json.checkout_url;
          return;
        }
        window.location.href = json.next || '/gracias';
      } catch (e2) {
        err.textContent = e2.message || 'Error al enviar brief';
        err.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = old;
      }
    });
  </script>
</Layout>

<style>select option { background:#111; color:white; }</style>
