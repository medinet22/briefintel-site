---
import Layout from '../layouts/Layout.astro';

const reportTypes = [
  { value: 'competitor-intel', label: 'Competitor Intel — €35' },
  { value: 'market-entry', label: 'Market Entry Brief — €49' },
  { value: 'buyer-intel', label: 'Buyer Intel M&A — €59' },
  { value: 'talent-market', label: 'Talent Market Intel — €19' },
  { value: 'pack', label: 'Pack Completo (4 reportes) — €119' },
];

const preTipo = Astro.url.searchParams.get('tipo') || '';
---

<Layout title="Brief de tu reporte — BriefIntel">
  <div class="min-h-screen bg-dark pt-8 pb-24 px-6">
    <div class="max-w-2xl mx-auto">

      <div class="text-center mb-12 pt-8">
        <a href="/" class="inline-block mb-8">
          <span class="text-accent font-black text-2xl tracking-tight">BRIEF<span class="text-white">INTEL</span></span>
        </a>
        <h1 class="text-3xl md:text-4xl font-bold mb-4">Completa tu brief (5 min)</h1>
        <p class="text-white/60 text-lg max-w-lg mx-auto">Primero guardamos tu brief, luego te llevamos al pago seguro con Stripe.</p>
      </div>

      <form id="briefForm" class="space-y-6">
        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6">
          <label class="block text-sm font-semibold text-accent uppercase tracking-wider mb-3">Tipo de reporte</label>
          <select id="tipo_reporte" name="tipo_reporte" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm">
            <option value="" disabled selected class="bg-dark">Selecciona el tipo de reporte</option>
            {reportTypes.map(r => (<option value={r.value} class="bg-dark">{r.label}</option>))}
          </select>
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 space-y-4">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">Tu empresa</h3>
          <input type="text" name="empresa_nombre" required placeholder="Nombre de tu empresa" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <input type="url" name="empresa_web" required placeholder="https://tuempresa.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <div class="grid grid-cols-2 gap-4">
            <input type="text" name="sector" required placeholder="Sector" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
            <select name="tamano" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm">
              <option value="1" class="bg-dark">Solo yo</option>
              <option value="2-10" class="bg-dark">2-10 personas</option>
              <option value="11-50" selected class="bg-dark">11-50 personas</option>
              <option value="50+" class="bg-dark">Más de 50</option>
            </select>
          </div>
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 space-y-3">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">1) Enfoque principal del reporte</h3>
          <p class="text-xs text-white/50">Empieza con una pregunta guía. Es opcional, pero nos ayuda a aterrizar el análisis en lo que más te importa.</p>
          <textarea id="pregunta_1" name="pregunta_1" rows="3" placeholder="Esta pregunta se adapta automáticamente al tipo de reporte" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 space-y-3">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">2) Decisión que necesitas tomar (requerido)</h3>
          <p class="text-xs text-white/50">Esto sí es obligatorio. Define la decisión concreta que quieres resolver con el reporte.</p>
          <textarea name="decision" required rows="3" placeholder="Ejemplo: ¿deberíamos entrar al mercado X este trimestre o esperar 6 meses?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 space-y-4">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">3) Información adicional (opcional)</h3>
          <p class="text-xs text-white/50">Estas preguntas son opcionales. Cuanto más contexto compartas aquí, más fino y útil será el reporte final.</p>

          <textarea id="pregunta_2" rows="2" placeholder="Pregunta opcional 1" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
          <textarea id="pregunta_3" rows="2" placeholder="Pregunta opcional 2" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>
          <textarea id="pregunta_4" rows="2" placeholder="Pregunta opcional 3" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>

          <textarea id="pregunta_pack_extra" rows="2" placeholder="Pregunta opcional 4 (solo pack completo)" class="hidden w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea>

          <input type="hidden" name="preguntas_clave" id="preguntas_clave" />
        </div>

        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">4) Email de entrega</h3>
          <p class="text-xs text-white/50 mb-3">Te enviaremos confirmación y el estado de tu pedido a este correo.</p>
          <input type="email" name="email" required placeholder="tu@empresa.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" />
          <input type="hidden" name="sujeto_nombre" id="sujeto_nombre" />
          <input type="hidden" name="sujeto_web" value="" />
          <label class="mt-3 flex items-start gap-2 text-xs text-white/60">
            <input type="checkbox" name="consent" required class="mt-0.5" />
            Acepto recibir comunicaciones sobre mi brief y reporte.
          </label>
        </div>

        <button id="submitBtn" type="submit" class="w-full bg-accent hover:bg-accent/90 text-dark py-4 rounded-xl text-lg font-bold">Guardar brief y continuar al pago</button>
        <p id="errorMsg" class="text-red-300 text-sm hidden"></p>
      </form>
    </div>
  </div>

  <script is:inline>
    const preTipo = new URLSearchParams(location.search).get('tipo');
    const tipoSelect = document.getElementById('tipo_reporte');
    const pregunta1 = document.getElementById('pregunta_1');
    const pregunta2 = document.getElementById('pregunta_2');
    const pregunta3 = document.getElementById('pregunta_3');
    const pregunta4 = document.getElementById('pregunta_4');
    const preguntaPackExtra = document.getElementById('pregunta_pack_extra');
    const preguntasClave = document.getElementById('preguntas_clave');
    const sujetoNombre = document.getElementById('sujeto_nombre');

    const dynamicPromptByReport = {
      'competitor-intel': '¿Qué rival o movimiento competitivo te preocupa más ahora mismo?',
      'market-entry': '¿Qué mercado o segmento estás evaluando y qué duda te bloquea?',
      'buyer-intel': '¿Qué tipo de comprador o inversor quieres entender mejor?',
      'talent-market': '¿Qué perfil de talento es más crítico para tu siguiente etapa?',
      'pack': '¿Cuál es la decisión más importante que quieres resolver con el pack completo?'
    };

    const optionalPromptsByReport = {
      'competitor-intel': [
        '¿Qué competidores quieres priorizar y por qué?',
        '¿Qué señales del mercado te generan más incertidumbre?',
        '¿Qué resultado concreto esperas del reporte para actuar?'
      ],
      'market-entry': [
        '¿Qué país/ciudad/segmento quieres evaluar primero?',
        '¿Qué límites de inversión o tiempo tienes para entrar?',
        '¿Qué riesgo te preocupa más: demanda, competencia o ejecución?'
      ],
      'buyer-intel': [
        '¿Qué tipo de operación te interesa analizar (venta total, parcial, inversión)?',
        '¿Qué rango de valoración consideras razonable hoy?',
        '¿Qué perfil de buyer crees que tendría más fit contigo?'
      ],
      'talent-market': [
        '¿Qué puestos quieres cubrir en los próximos 3-6 meses?',
        '¿Qué modalidad te interesa más (remoto, híbrido, presencial)?',
        '¿Qué problema quieres resolver primero: atracción, salario o retención?'
      ],
      'pack': [
        '¿Qué frente quieres priorizar primero: competencia, mercado, buyer o talento?',
        '¿Cuál es el mayor cuello de botella actual de tu negocio?',
        '¿Qué decisión concreta quieres tomar justo después de recibir el pack?',
        '¿Qué hipótesis quieres validar o descartar con este análisis?'
      ]
    };

    const setDynamicQuestionPlaceholder = () => {
      const tipo = tipoSelect?.value || '';
      const dynamic = dynamicPromptByReport[tipo] || 'Cuéntanos qué te gustaría aclarar con este reporte';
      if (pregunta1) pregunta1.placeholder = dynamic;

      const prompts = optionalPromptsByReport[tipo] || [];
      if (pregunta2) pregunta2.placeholder = prompts[0] || 'Pregunta opcional 1';
      if (pregunta3) pregunta3.placeholder = prompts[1] || 'Pregunta opcional 2';
      if (pregunta4) pregunta4.placeholder = prompts[2] || 'Pregunta opcional 3';

      const isPack = tipo === 'pack';
      if (preguntaPackExtra) {
        preguntaPackExtra.classList.toggle('hidden', !isPack);
        preguntaPackExtra.placeholder = prompts[3] || 'Pregunta opcional 4 (solo pack completo)';
      }
    };

    if (preTipo) tipoSelect.value = preTipo;
    setDynamicQuestionPlaceholder();
    tipoSelect?.addEventListener('change', setDynamicQuestionPlaceholder);

    const form = document.getElementById('briefForm');
    const btn = document.getElementById('submitBtn');
    const err = document.getElementById('errorMsg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      err.classList.add('hidden');
      const old = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Guardando brief...';

      const tipo = tipoSelect?.value || '';
      const p1 = (pregunta1?.value || '').trim();
      const p2 = (pregunta2?.value || '').trim();
      const p3 = (pregunta3?.value || '').trim();
      const p4 = (pregunta4?.value || '').trim();
      const pPack = (preguntaPackExtra?.value || '').trim();

      const mergedParts = [
        p1 ? `Enfoque principal (opcional): ${p1}` : '',
        p2 ? `Pregunta opcional 1: ${p2}` : '',
        p3 ? `Pregunta opcional 2: ${p3}` : '',
        p4 ? `Pregunta opcional 3: ${p4}` : '',
        (tipo === 'pack' && pPack) ? `Pregunta opcional 4: ${pPack}` : '',
      ].filter(Boolean);

      if (preguntasClave) preguntasClave.value = mergedParts.join('\n');

      const sujetoByTipo = {
        'competitor-intel': 'Análisis competitivo',
        'market-entry': 'Análisis de entrada a mercado',
        'buyer-intel': 'Análisis de compradores potenciales',
        'talent-market': 'Análisis de mercado de talento',
        'pack': 'Análisis estratégico integral'
      };
      if (sujetoNombre) sujetoNombre.value = sujetoByTipo[tipo] || 'Análisis estratégico';

      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch('/api/brief', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error || 'No se pudo guardar el brief');
        if (json.checkout_url) {
          btn.textContent = 'Redirigiendo a pago...';
          window.location.href = json.checkout_url;
          return;
        }
        window.location.href = json.next || '/gracias';
      } catch (e2) {
        err.textContent = e2.message || 'Error al enviar brief';
        err.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = old;
      }
    });
  </script>
</Layout>

<style>select option { background:#111; color:white; }</style>
