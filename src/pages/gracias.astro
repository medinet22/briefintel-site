---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pago confirmado — BriefIntel">
  <div class="min-h-screen bg-dark flex items-center justify-center px-6">

    <!-- Loading -->
    <div id="loadingState" class="text-center">
      <div class="w-10 h-10 border-2 border-accent border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
      <p class="text-white/60 text-sm">Verificando tu pago...</p>
    </div>

    <!-- Success -->
    <div id="successState" class="hidden max-w-lg mx-auto text-center">
      <div class="w-20 h-20 bg-green-500/10 border border-green-500/20 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-3xl font-bold mb-4">¡Pago confirmado! <span class="text-accent">Estamos en ello.</span></h1>
      <p class="text-white/60 text-lg mb-8">
        Recibirás una confirmación por email ahora mismo. Tu reporte estará en tu bandeja en <strong class="text-white">menos de 24 horas.</strong>
      </p>
      <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 text-left mb-8">
        <h3 class="text-sm font-semibold text-accent uppercase tracking-wider mb-4">Mientras tanto</h3>
        <ul class="space-y-3 text-sm text-white/60">
          <li class="flex gap-3"><span class="text-accent">→</span> Revisa tu carpeta de spam si no ves la confirmación</li>
          <li class="flex gap-3"><span class="text-accent">→</span> Si tienes archivos adicionales, envíalos a <span class="text-accent">hola@getbriefintel.com</span></li>
          <li class="flex gap-3"><span class="text-accent">→</span> ¿Preguntas? Responde al email de confirmación</li>
        </ul>
      </div>
      <a href="/" class="inline-flex items-center gap-2 text-white/40 hover:text-white text-sm transition-colors">
        ← Volver a getbriefintel.com
      </a>
    </div>

    <!-- Error / not paid -->
    <div id="errorState" class="hidden max-w-sm mx-auto text-center">
      <div class="w-14 h-14 bg-yellow-500/10 border border-yellow-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h2 class="text-xl font-bold mb-2">Pago pendiente</h2>
      <p class="text-white/60 text-sm mb-6" id="errorText">No pudimos confirmar tu pago. Si crees que es un error, escríbenos a hola@getbriefintel.com</p>
      <a href="/" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white px-6 py-3 rounded-xl font-bold text-sm transition-colors">← Volver al inicio</a>
    </div>

  </div>
</Layout>

<script is:inline>
(async () => {
  const params = new URLSearchParams(location.search);
  const paymentIntent = params.get('payment_intent');
  const clientSecret = params.get('payment_intent_client_secret');

  function showSuccess() {
    document.getElementById('loadingState').classList.add('hidden');
    document.getElementById('successState').classList.remove('hidden');
  }
  function showError(msg) {
    document.getElementById('loadingState').classList.add('hidden');
    document.getElementById('errorState').classList.remove('hidden');
    if (msg) document.getElementById('errorText').textContent = msg;
  }

  // If no payment_intent param, maybe came from old checkout flow — just show success
  if (!paymentIntent || !clientSecret) {
    showSuccess();
    return;
  }

  // Verify status with Stripe.js (no backend call needed — clientSecret is safe for frontend)
  // We need Stripe.js to retrieve the PaymentIntent status
  if (!window.Stripe) {
    // Stripe.js not loaded yet — wait briefly then retry
    await new Promise(r => setTimeout(r, 1500));
  }

  try {
    // Fetch publishable key from our backend (simple ping)
    const res = await fetch(`/api/create-payment-intent?verify=1&payment_intent=${encodeURIComponent(paymentIntent)}`);
    if (!res.ok) throw new Error('verify failed');
    const data = await res.json();

    if (!data.publishableKey) throw new Error('no key');

    const stripe = window.Stripe(data.publishableKey);
    const { paymentIntent: pi, error } = await stripe.retrievePaymentIntent(clientSecret);

    if (error) throw new Error(error.message);

    if (pi.status === 'succeeded') {
      showSuccess();
    } else if (pi.status === 'processing') {
      showSuccess(); // Show success, webhook will confirm
    } else {
      showError(`El pago no pudo completarse (${pi.status}). Si el importe fue cargado, contáctanos en hola@getbriefintel.com`);
    }
  } catch (e) {
    // If verification fails, still show success (webhook is source of truth)
    showSuccess();
  }
})();
</script>

<script src="https://js.stripe.com/v3/" is:inline></script>
