---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pago seguro — BriefIntel">
  <div class="min-h-screen bg-dark">
    <!-- Header -->
    <div class="border-b border-white/10 px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="text-accent font-black text-xl tracking-tight">BRIEF<span class="text-white">INTEL</span></a>
        <div class="flex items-center gap-2 text-white/40 text-sm">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
          <span>Pago seguro con SSL</span>
        </div>
      </div>
    </div>

    <!-- Loading state -->
    <div id="loadingState" class="flex items-center justify-center min-h-[60vh]">
      <div class="text-center">
        <div class="w-10 h-10 border-2 border-accent border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-white/60 text-sm">Preparando tu pago...</p>
      </div>
    </div>

    <!-- Error state -->
    <div id="errorState" class="hidden flex items-center justify-center min-h-[60vh] px-6">
      <div class="text-center max-w-sm">
        <div class="w-14 h-14 bg-red-500/10 border border-red-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </div>
        <h2 class="text-xl font-bold mb-2">Algo salió mal</h2>
        <p id="errorText" class="text-white/60 text-sm mb-6">No pudimos cargar la página de pago.</p>
        <a href="/brief" class="inline-flex items-center gap-2 bg-accent text-dark px-6 py-3 rounded-xl font-bold text-sm hover:bg-accent/90 transition-colors">← Volver al brief</a>
      </div>
    </div>

    <!-- Payment form (shown once Stripe loads) -->
    <div id="paymentLayout" class="hidden max-w-5xl mx-auto px-6 py-12">
      <div class="grid md:grid-cols-[1fr_1.1fr] gap-8 items-start">

        <!-- LEFT: Order summary -->
        <div class="space-y-6">
          <!-- Urgency badge -->
          <div class="bg-amber-500/10 border border-amber-500/30 rounded-xl px-4 py-3 mb-4 flex items-center gap-2">
            <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span>
            <span class="text-sm text-amber-400">Solo aceptamos 3 pedidos/día para garantizar calidad</span>
          </div>

          <!-- Order card -->
          <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6">
            <p class="text-xs font-semibold text-accent uppercase tracking-wider mb-4">Tu pedido</p>

            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <h2 id="orderReportName" class="text-lg font-bold text-white">—</h2>
                <p id="orderEmpresa" class="text-white/50 text-sm mt-0.5">—</p>
              </div>
              <div class="text-right">
                <p id="orderAmount" class="text-2xl font-black text-accent">—</p>
                <p class="text-white/30 text-xs">IVA incl.</p>
              </div>
            </div>

            <div class="border-t border-white/10 pt-4 space-y-2.5">
              <div class="flex items-center gap-2.5 text-sm text-white/60">
                <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                Entrega en menos de 24 horas
              </div>
              <div class="flex items-center gap-2.5 text-sm text-white/60">
                <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                Garantía de devolución 7 días
              </div>
              <div class="flex items-center gap-2.5 text-sm text-white/60">
                <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                Análisis con IA de última generación
              </div>
              <div class="flex items-center gap-2.5 text-sm text-white/60">
                <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                PDF descargable + fuentes verificadas
              </div>
            </div>
          </div>

          <!-- Trust signals -->
          <div class="bg-white/[0.02] border border-white/8 rounded-2xl p-5">
            <p class="text-xs font-semibold text-white/30 uppercase tracking-wider mb-3">Pago 100% seguro</p>
            <div class="flex items-center gap-3 flex-wrap">
              <div class="flex items-center gap-1.5 text-white/50 text-xs">
                <svg class="w-4 h-4 text-white/30" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                Stripe SSL 256-bit
              </div>
              <div class="text-white/20">·</div>
              <div class="flex items-center gap-1.5 text-white/50 text-xs">
                <svg class="w-4 h-4 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                PCI DSS compliant
              </div>
              <div class="text-white/20">·</div>
              <span class="text-white/40 text-xs">Visa · Mastercard · Amex · Apple Pay</span>
            </div>
          </div>

          <!-- Cancelación -->
          <p class="text-white/30 text-xs leading-relaxed px-1">
            Tu brief ya está guardado. Si cancelas el pago, puedes retomarlo cuando quieras escribiéndonos a <span class="text-accent/60">hola@getbriefintel.com</span>.
          </p>
        </div>

        <!-- RIGHT: Payment form -->
        <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6 md:p-8">
          <p class="text-xs font-semibold text-accent uppercase tracking-wider mb-6">Introduce tus datos de pago</p>

          <form id="paymentForm">
            <div id="payment-element" class="mb-6">
              <!-- Stripe Payment Element mounts here -->
            </div>

            <div id="payment-message" class="hidden bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-red-300 text-sm mb-4"></div>

            <button id="payBtn" type="submit"
              class="w-full bg-accent hover:bg-accent/90 disabled:opacity-50 disabled:cursor-not-allowed text-dark py-4 rounded-xl text-base font-bold transition-colors flex items-center justify-center gap-2">
              <svg id="payBtnLock" class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
              <span id="payBtnText">Pagar <span id="payBtnAmount">—</span></span>
              <div id="payBtnSpinner" class="hidden w-4 h-4 border-2 border-dark border-t-transparent rounded-full animate-spin"></div>
            </button>

            <p class="text-center text-white/30 text-xs mt-4">
              Al pagar aceptas nuestros <a href="/privacidad" class="text-white/50 hover:text-white underline">términos y condiciones</a>. Garantía de devolución de 7 días.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script src="https://js.stripe.com/v3/" is:inline></script>

<script is:inline>
(async () => {
  const params = new URLSearchParams(location.search);
  const briefId = params.get('brief_id');

  function showError(msg) {
    document.getElementById('loadingState').classList.add('hidden');
    document.getElementById('errorState').classList.remove('hidden');
    document.getElementById('errorText').textContent = msg || 'Error al cargar el pago.';
  }

  if (!briefId) {
    showError('No se encontró tu brief. Vuelve al formulario e inténtalo de nuevo.');
    return;
  }

  // Fetch PaymentIntent data from backend — forward all params for serverless fallback
  let piData;
  try {
    const res = await fetch(`/api/create-payment-intent?${params.toString()}`);
    piData = await res.json();
    if (!res.ok || !piData.ok) throw new Error(piData.error || 'Error de servidor');
  } catch (e) {
    showError(e.message || 'No pudimos preparar el pago. Intenta de nuevo en un momento.');
    return;
  }

  // Populate order summary
  const amountFormatted = `€${(piData.amount / 100).toFixed(0)}`;
  document.getElementById('orderReportName').textContent = piData.reportName || '—';
  document.getElementById('orderEmpresa').textContent = piData.empresa || '—';
  document.getElementById('orderAmount').textContent = amountFormatted;
  document.getElementById('payBtnAmount').textContent = amountFormatted;

  // Init Stripe
  if (!window.Stripe) { showError('No se pudo cargar Stripe. Recarga la página.'); return; }
  const stripe = window.Stripe(piData.publishableKey);
  const elements = stripe.elements({ clientSecret: piData.clientSecret, locale: 'es', appearance: {
    theme: 'night',
    variables: {
      colorPrimary: '#f59e0b',
      colorBackground: '#161616',
      colorText: '#f1f5f9',
      colorDanger: '#ef4444',
      fontFamily: 'system-ui, sans-serif',
      borderRadius: '12px',
      spacingUnit: '4px',
    },
    rules: {
      '.Input': { border: '1px solid rgba(255,255,255,0.12)', backgroundColor: 'rgba(255,255,255,0.04)', padding: '12px 16px' },
      '.Input:focus': { border: '1px solid rgba(245,158,11,0.6)', boxShadow: '0 0 0 2px rgba(245,158,11,0.15)' },
      '.Label': { color: 'rgba(241,245,249,0.7)', fontSize: '13px', fontWeight: '500' },
    }
  }});

  const paymentElement = elements.create('payment');
  paymentElement.mount('#payment-element');

  // Show layout
  document.getElementById('loadingState').classList.add('hidden');
  document.getElementById('paymentLayout').classList.remove('hidden');

  // Handle submit
  const form = document.getElementById('paymentForm');
  const payBtn = document.getElementById('payBtn');
  const payBtnText = document.getElementById('payBtnText');
  const payBtnSpinner = document.getElementById('payBtnSpinner');
  const payBtnLock = document.getElementById('payBtnLock');
  const msgEl = document.getElementById('payment-message');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    payBtn.disabled = true;
    payBtnText.classList.add('hidden');
    payBtnLock.classList.add('hidden');
    payBtnSpinner.classList.remove('hidden');
    msgEl.classList.add('hidden');

    const { error } = await stripe.confirmPayment({
      elements,
      confirmParams: {
        return_url: `${location.origin}/gracias?brief_id=${encodeURIComponent(briefId)}&tipo=${encodeURIComponent(piData.tipo || '')}`,
        receipt_email: piData.email || undefined,
      },
    });

    // Only reached on error (success redirects)
    if (error) {
      let userMsg = error.message;
      if (error.type === 'card_error' || error.type === 'validation_error') {
        userMsg = error.message;
      } else {
        userMsg = 'Ocurrió un error inesperado. Intenta de nuevo.';
      }
      msgEl.textContent = userMsg;
      msgEl.classList.remove('hidden');
    }

    payBtn.disabled = false;
    payBtnText.classList.remove('hidden');
    payBtnLock.classList.remove('hidden');
    payBtnSpinner.classList.add('hidden');
  });
})();
</script>
