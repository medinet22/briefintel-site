---
const reports = [
  {
    id: "competitor-intel",
    name: "COMPETITOR INTEL",
    question: "¿Estás perdiendo clientes sin saber por qué?",
    price: "€35",
    priceNum: 35,
    delivery: "Entrega 24h",
    description: "Descubre exactamente qué está haciendo tu competidor: su estrategia de precios, sus movimientos recientes y sus puntos débiles que puedes explotar.",
    features: [
      "Qué está haciendo diferente (y funcionando)",
      "Movimientos recientes que afectan tu decisión",
      "Puntos débiles que puedes explotar",
      "Plan de ataque concreto para los próximos 30 días"
    ],
    icon: "🎯",
    useCase: "Ideal si: pierdes clientes y no sabes por qué, o tu competidor crece más rápido",
    link: "https://buy.stripe.com/eVq4gA0rSg2pdjc8pDaEE05"
  },
  {
    id: "market-entry",
    name: "MARKET ENTRY BRIEF",
    question: "¿Vale la pena entrar a ese mercado?",
    price: "€49",
    priceNum: 49,
    delivery: "Entrega 24h",
    description: "Antes de entrar a un nuevo mercado, país o segmento: saber si vale la pena, quién ya está ahí y cómo posicionarte para ganar. Sin meses de análisis interno.",
    features: [
      "Tamaño real del mercado y tendencias",
      "Quién ya está y qué hacen",
      "Barreras de entrada y riesgos",
      "Cuándo y cómo atacar — recomendación go/no-go"
    ],
    icon: "🌍",
    useCase: "Ideal si: evalúas expansión geográfica o nuevo segmento de clientes",
    link: "https://buy.stripe.com/aFabJ2b6w2bz6UO21faEE04"
  },
  {
    id: "buyer-intel",
    name: "BUYER INTEL · M&A",
    question: "¿Quién compraría tu empresa — y a qué precio?",
    price: "€59",
    priceNum: 59,
    delivery: "Entrega 24h",
    description: "Para founders que preparan un exit, buscan inversión o quieren saber quién podría adquirirles. Analizamos compradores potenciales: capacidad financiera, historial y cómo maximizar tu valoración.",
    features: [
      "Perfil financiero del comprador o fondo inversor",
      "Historial real de adquisiciones e inversiones",
      "Qué criterios usan para decir sí (y qué les frena)",
      "Cómo posicionarte para máxima valoración"
    ],
    icon: "💼",
    useCase: "Ideal si: preparas un exit, buscas inversión o evalúas potenciales compradores",
    link: "https://buy.stripe.com/00w00keiIcQd5QKbBPaEE03"
  },
  {
    id: "talent-market",
    name: "TALENT MARKET INTEL",
    question: "¿Cómo es el mercado de talento en tu sector?",
    price: "€19",
    priceNum: 19,
    delivery: "Entrega 24h",
    description: "Análisis del mercado de talento en tu sector: qué perfiles dominan, qué habilidades escasean, qué pagan los competidores y dónde están los mejores candidatos.",
    features: [
      "Mapa de perfiles dominantes en tu sector",
      "Rangos salariales y condiciones del mercado",
      "Dónde están y cómo atraer a los mejores",
      "Tendencias emergentes en el mercado de talento"
    ],
    icon: "📊",
    useCase: "Ideal si: quieres entender el mercado de talento antes de contratar o posicionarte como employer",
    link: "https://buy.stripe.com/14A4gAb6w03r7YScFTaEE06"
  }
];
---

<section id="reportes" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-3">
        ¿Cuál es tu pregunta?
      </h2>
      <p class="text-white/50 text-base max-w-xl mx-auto mb-4">
        Haz clic en el reporte que responde a lo que necesitas saber ahora.
      </p>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-white/50">
        <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        Limitado a 3 reportes/día para garantizar máxima calidad
      </div>
    </div>

    <!-- Tap hint -->
    <p class="text-center text-white/30 text-xs mb-4 md:hidden">👆 Toca la tarjeta del reporte que necesitas</p>

    <!-- Report Cards Grid -->
    <div class="grid lg:grid-cols-4 md:grid-cols-2 gap-4 mb-6" id="report-cards">
      {reports.map((report) => (
        <div
          class="report-card group relative flex flex-col bg-white/[0.03] border border-white/10 rounded-2xl p-5 cursor-pointer transition-all duration-300 hover:border-accent/60 hover:bg-white/[0.07] hover:shadow-lg hover:shadow-accent/10 hover:-translate-y-1"
          data-id={report.id}
          data-price={report.price}
          data-name={report.name}
        >
          <!-- Selected indicator -->
          <div class="selected-badge absolute top-3 right-3 w-6 h-6 bg-accent rounded-full items-center justify-center hidden">
            <svg class="w-3.5 h-3.5 text-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
          </div>

          <!-- Top: icon + price -->
          <div class="flex items-center justify-between mb-4">
            <span class="text-3xl">{report.icon}</span>
            <div class="text-right">
              <div class="text-2xl font-black text-accent">{report.price}</div>
              <div class="text-xs text-white/40">· 24h</div>
            </div>
          </div>

          <!-- Category label -->
          <p class="text-[10px] font-bold tracking-widest text-white/30 uppercase mb-1">{report.name}</p>

          <!-- Question — la promesa -->
          <p class="text-base font-bold text-white leading-snug mb-3">{report.question}</p>

          <!-- 3 bullets concisos -->
          <ul class="space-y-1.5 mb-4">
            {report.features.slice(0,3).map((feature) => (
              <li class="flex items-start gap-2 text-xs text-white/60 leading-snug">
                <span class="text-accent mt-0.5 flex-shrink-0">✓</span>
                {feature}
              </li>
            ))}
          </ul>

          <!-- Spacer to push button to bottom -->
          <div class="flex-1"></div>

          <!-- CTA button — siempre visible, sólido -->
          <div class="mt-auto pt-2">
            <div class="select-btn flex items-center justify-center gap-1.5 w-full bg-accent text-dark py-3 rounded-xl text-sm font-bold transition-all duration-200 hover:bg-accent/90">
              Elegir este reporte →
            </div>
            <div class="selected-btn hidden items-center justify-center gap-1.5 w-full bg-green-500 text-dark py-3 rounded-xl text-sm font-bold">
              ✓ Seleccionado
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Order Summary (hidden until a card is selected) -->
    <div id="order-summary" class="hidden">
      <div class="bg-accent/5 border-2 border-accent/30 rounded-2xl p-6 md:p-8 transition-all duration-300">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
          <div class="flex-1">
            <p class="text-xs text-accent font-bold uppercase tracking-wider mb-1">Reporte seleccionado</p>
            <h3 id="summary-name" class="text-xl font-bold text-white mb-1"></h3>
            <p class="text-sm text-white/60">Primero completas tu brief (2-5 min), luego pago seguro con Stripe.</p>
          </div>
          <div class="flex items-center gap-6">
            <div class="text-right">
              <div id="summary-price" class="text-4xl font-black text-accent"></div>
              <div class="text-xs text-white/40">pago único</div>
            </div>
            <a
              id="summary-cta"
              href="#"

              class="inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-dark px-8 py-4 rounded-xl font-bold text-base transition-all duration-200 hover:scale-[1.03] hover:shadow-lg hover:shadow-accent/25 whitespace-nowrap"
            >
              Completar brief →
            </a>
          </div>
        </div>
        <div class="flex flex-wrap gap-4 mt-4 pt-4 border-t border-accent/10 text-xs text-white/40">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Sin suscripción
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Garantía 7 días
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            🔒 Stripe seguro
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Factura automática
          </span>
        </div>
        <p class="text-xs text-white/30 mt-3 text-center">
          ¿Prefieres los 4 reportes? <a href="#pack" class="text-accent hover:underline">Pack Estratégico — €119 (ahorra €43)</a>
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const cards = document.querySelectorAll('.report-card');
  const summary = document.getElementById('order-summary');
  const summaryName = document.getElementById('summary-name');
  const summaryPrice = document.getElementById('summary-price');
  const summaryCta = document.getElementById('summary-cta');

  let selectedId: string | null = null;

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const id = card.getAttribute('data-id')!;
      const name = card.getAttribute('data-name')!;
      const price = card.getAttribute('data-price')!;
      const link = `/brief?tipo=${encodeURIComponent(id)}`;

      // Toggle: click same card = deselect
      if (selectedId === id) {
        deselectAll();
        return;
      }

      selectedId = id;

      // Reset all cards
      cards.forEach(c => {
        c.classList.remove('border-accent', 'bg-accent/[0.06]');
        c.classList.add('border-white/10', 'bg-white/[0.02]');
        const badge = c.querySelector('.selected-badge') as HTMLElement;
        const selectBtn = c.querySelector('.select-btn') as HTMLElement;
        const selectedBtn = c.querySelector('.selected-btn') as HTMLElement;
        if (badge) badge.classList.add('hidden'), badge.classList.remove('flex');
        if (selectBtn) selectBtn.classList.remove('hidden');
        if (selectedBtn) selectedBtn.classList.add('hidden'), selectedBtn.classList.remove('flex');
      });

      // Activate clicked card
      card.classList.add('border-accent', 'bg-accent/[0.06]');
      card.classList.remove('border-white/10', 'bg-white/[0.02]');
      const badge = card.querySelector('.selected-badge') as HTMLElement;
      const selectBtn = card.querySelector('.select-btn') as HTMLElement;
      const selectedBtn = card.querySelector('.selected-btn') as HTMLElement;
      if (badge) badge.classList.remove('hidden'), badge.classList.add('flex');
      if (selectBtn) selectBtn.classList.add('hidden');
      if (selectedBtn) selectedBtn.classList.remove('hidden'), selectedBtn.classList.add('flex');

      // Update and show summary
      summaryName!.textContent = name.replace('·', '·').replace(' · ', ' · ');
      summaryPrice!.textContent = price;
      summaryCta!.setAttribute('href', link);
      summary!.classList.remove('hidden');

      // Smooth scroll to summary
      setTimeout(() => {
        summary!.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 100);
    });
  });

  function deselectAll() {
    selectedId = null;
    cards.forEach(c => {
      c.classList.remove('border-accent', 'bg-accent/[0.06]');
      c.classList.add('border-white/10', 'bg-white/[0.02]');
      const badge = c.querySelector('.selected-badge') as HTMLElement;
      const selectBtn = c.querySelector('.select-btn') as HTMLElement;
      const selectedBtn = c.querySelector('.selected-btn') as HTMLElement;
      if (badge) badge.classList.add('hidden'), badge.classList.remove('flex');
      if (selectBtn) selectBtn.classList.remove('hidden');
      if (selectedBtn) selectedBtn.classList.add('hidden'), selectedBtn.classList.remove('flex');
    });
    summary!.classList.add('hidden');
  }
</script>
