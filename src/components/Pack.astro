---
---

<section id="pack" class="pt-6 pb-20 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="relative bg-gradient-to-br from-amber-500/10 via-amber-500/5 to-transparent border-2 border-amber-500/40 rounded-3xl p-8 md:p-12 mt-6">
      <!-- Decorative elements -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-amber-500/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-amber-500/5 rounded-full blur-2xl translate-y-1/2 -translate-x-1/2"></div>
      
      <!-- Badge -->
      <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-amber-500 text-dark text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full shadow-lg">
        ⚡ Más vendido — Ahorra €43
      </div>
      
      <div class="relative z-10">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Pack Estratégico Completo
          </h2>
          <p class="text-white/70 text-lg max-w-xl mx-auto">
            Los 4 reportes BriefIntel: Competitor Intel + Market Entry Brief + Buyer Intel M&A + Talent Intel.
          </p>
        </div>
        
        <!-- What's included -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
          <div class="bg-white/5 rounded-xl p-5 border border-white/10">
            <div class="text-2xl mb-3">🎯</div>
            <h3 class="font-semibold mb-2 text-sm">Competitor Intel</h3>
            <p class="text-xs text-white/60">Qué hace tu competidor, sus debilidades y cómo atacar.</p>
            <p class="text-xs text-white/40 mt-2">Valor: €35</p>
          </div>
          <div class="bg-white/5 rounded-xl p-5 border border-white/10">
            <div class="text-2xl mb-3">🌍</div>
            <h3 class="font-semibold mb-2 text-sm">Market Entry Brief</h3>
            <p class="text-xs text-white/60">Si vale la pena entrar al mercado, riesgos y timing.</p>
            <p class="text-xs text-white/40 mt-2">Valor: €49</p>
          </div>
          <div class="bg-white/5 rounded-xl p-5 border border-white/10">
            <div class="text-2xl mb-3">💼</div>
            <h3 class="font-semibold mb-2 text-sm">Buyer Intel M&A</h3>
            <p class="text-xs text-white/60">Perfil de compradores potenciales de tu empresa o inversores.</p>
            <p class="text-xs text-white/40 mt-2">Valor: €59</p>
          </div>
          <div class="bg-white/5 rounded-xl p-5 border border-white/10">
            <div class="text-2xl mb-3">📊</div>
            <h3 class="font-semibold mb-2 text-sm">Talent Market Intel</h3>
            <p class="text-xs text-white/60">Análisis del mercado de talento y perfiles de tu sector.</p>
            <p class="text-xs text-white/40 mt-2">Valor: €19</p>
          </div>
        </div>
        
        <!-- Price and CTA -->
        <div class="text-center">
          <div class="flex items-center justify-center gap-4 mb-6">
            <span class="text-2xl text-white/40 line-through">€162</span>
            <span class="text-5xl md:text-6xl font-black text-amber-500">€119</span>
            <span class="text-white/40 text-sm">pago único</span>
          </div>
          
          <a 
            href="/brief?tipo=pack"
            class="inline-flex items-center justify-center gap-2 bg-amber-500 text-dark px-10 py-4 rounded-xl text-lg font-bold hover:bg-amber-400 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-amber-500/30 mb-3"
          >
            Elegir Pack Completo — €119
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <p class="text-xs text-white/30 mb-6">Primero completas el brief (5 min), luego checkout seguro Stripe · Entrega en 24-48h</p>
          
          <!-- Trust signals -->
          <div class="flex flex-wrap justify-center gap-4 text-sm text-white/50">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Entrega en 24-48h
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Factura automática
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Garantía 7 días
            </span>
          </div>
        </div>
      </div>
    </div>
    
    <p class="text-center text-white/40 text-sm mt-6">
      ¿Solo necesitas un reporte? <a href="#reportes" class="text-accent hover:underline">Ver reportes individuales</a>
    </p>
  </div>
</section>
