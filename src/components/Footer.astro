---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 px-6 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-8">
        <a href="/" class="text-xl font-bold tracking-tight">
          <span class="text-white">Brief</span><span class="text-accent">Intel</span>
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm text-white/50">
          <a href="#reportes" class="hover:text-white transition-colors">Reportes</a>
          <a href="#precios" class="hover:text-white transition-colors">Precios</a>
          <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
        </nav>
      </div>
      
      <div class="flex items-center gap-6">
        <a 
          href="mailto:hello@getbriefintel.com" 
          class="text-sm text-white/50 hover:text-accent transition-colors"
        >
          hello@getbriefintel.com
        </a>
      </div>
    </div>
    
    <div class="mt-8 pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-white/30">
      <p>© {currentYear} BriefIntel. Todos los derechos reservados.</p>
      <div class="flex items-center gap-6">
        <a href="/privacidad" class="hover:text-white/50 transition-colors">Política de Privacidad</a>
        <a href="/terminos" class="hover:text-white/50 transition-colors">Términos y Condiciones</a>
      </div>
    </div>
  </div>
</footer>
