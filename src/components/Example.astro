---
---

<section id="ejemplo" class="py-24 bg-dark relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-gold/5 rounded-full blur-3xl"></div>
  
  <div class="max-w-6xl mx-auto px-6 relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Content -->
      <div>
        <span class="inline-block text-gold text-xs font-bold uppercase tracking-wider mb-4">Ejemplo real</span>
        <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-6">
          Esto es lo que<br />
          <span class="text-gold">recibirás.</span>
        </h2>
        <p class="text-gray-light text-lg mb-8 leading-relaxed">
          No es un template genérico. Es inteligencia específica sobre TU competidor, TU mercado, TU buyer. Cada reporte es único.
        </p>
        
        <!-- What's inside -->
        <div class="space-y-4 mb-8">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 bg-gold/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h4 class="font-bold mb-1">Executive Summary en 1 página</h4>
              <p class="text-gray-light text-sm">Respuesta directa a tu pregunta. Puedes presentarlo al board sin editar.</p>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 bg-gold/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <div>
              <h4 class="font-bold mb-1">El "Insight Bomba"</h4>
              <p class="text-gray-light text-sm">Algo que no sabías y que cambia cómo piensas sobre la situación. Garantizado.</p>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 bg-gold/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <div>
              <h4 class="font-bold mb-1">5 acciones para las próximas 48h</h4>
              <p class="text-gray-light text-sm">No "considere evaluar". Acciones concretas con nombres, fechas, y métricas.</p>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 bg-gold/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h4 class="font-bold mb-1">Fuentes citadas inline</h4>
              <p class="text-gray-light text-sm">Cada claim con su fuente. Aguanta escrutinio del CFO más escéptico.</p>
            </div>
          </div>
        </div>
        
        <a 
          href="#pricing" 
          class="inline-flex items-center gap-2 bg-gold hover:bg-gold-dark text-black font-bold px-6 py-3 rounded-xl transition-all hover:scale-105"
        >
          Pedir mi reporte
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      
      <!-- Right: Report preview mock -->
      <div class="relative">
        <div class="bg-dark2 border border-dark3 rounded-2xl p-6 shadow-2xl">
          <!-- Report header -->
          <div class="flex items-center gap-4 pb-6 border-b border-dark3 mb-6">
            <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center">
              <span class="text-gold font-black text-lg">CI</span>
            </div>
            <div>
              <h4 class="font-bold text-lg">Competitor Intelligence Report</h4>
              <p class="text-gray text-sm">Acme Corp vs. CompetitorX — Marzo 2026</p>
            </div>
          </div>
          
          <!-- Executive summary mock -->
          <div class="mb-6">
            <div class="text-xs font-bold text-gold uppercase tracking-wider mb-3">Executive Summary</div>
            <div class="bg-black/50 rounded-xl p-4 border border-gold/20">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block px-2 py-0.5 bg-red-500/20 text-red-400 text-xs font-bold rounded">THREAT LEVEL: 7/10</span>
              </div>
              <p class="text-sm text-gray-light leading-relaxed">
                CompetitorX está pivotando agresivamente hacia enterprise con 8 nuevas contrataciones de sales en los últimos 60 días. Tu ventana para defender el segmento mid-market es de <span class="text-white font-semibold">4-6 meses</span>.
              </p>
            </div>
          </div>
          
          <!-- Insight bomba mock -->
          <div class="mb-6">
            <div class="text-xs font-bold text-gold uppercase tracking-wider mb-3">🔥 Insight Bomba</div>
            <div class="bg-gold/5 rounded-xl p-4 border border-gold/20">
              <p class="text-sm text-white leading-relaxed">
                CompetitorX bajó precios 22% en su tier "Growth" este mes (Wayback Machine, 28 Feb). Señal de presión en unit economics o guerra de precios inminente.
              </p>
            </div>
          </div>
          
          <!-- Actions mock -->
          <div>
            <div class="text-xs font-bold text-gold uppercase tracking-wider mb-3">Próximas 48 horas</div>
            <ul class="space-y-2">
              <li class="flex items-center gap-3 text-sm text-gray-light">
                <span class="w-6 h-6 bg-gold/10 rounded-full flex items-center justify-center text-gold font-bold text-xs">1</span>
                Revisar tu pricing del tier Growth esta semana
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-light">
                <span class="w-6 h-6 bg-gold/10 rounded-full flex items-center justify-center text-gold font-bold text-xs">2</span>
                Contactar a los 3 clientes en riesgo (lista en pág. 12)
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-light">
                <span class="w-6 h-6 bg-gold/10 rounded-full flex items-center justify-center text-gold font-bold text-xs">3</span>
                Lanzar feature X antes del 15 de abril
              </li>
            </ul>
          </div>
          
          <!-- Page indicator -->
          <div class="mt-6 pt-4 border-t border-dark3 flex justify-between items-center text-xs text-gray">
            <span>12-25 páginas de análisis profundo</span>
            <span class="text-gold">PDF descargable</span>
          </div>
        </div>
        
        <!-- Decorative elements -->
        <div class="absolute -bottom-4 -right-4 w-72 h-72 bg-gold/5 rounded-2xl -z-10"></div>
      </div>
    </div>
  </div>
</section>
