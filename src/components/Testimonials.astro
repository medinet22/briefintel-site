---
const testimonials = [
  {
    situation: "Perdíamos 2-3 licitaciones al mes frente al mismo competidor. Sabíamos que nos ganaban en precio, pero no por cuánto ni por qué.",
    action: "Pedimos el Competitor Intel un viernes por la tarde.",
    result: "El lunes descubrimos que incluían servicio postventa de 3 años. Añadimos lo mismo y bajamos margen un 5%. Ese mes ganamos las 2 siguientes licitaciones: €180K en contratos.",
    name: "Javier L.",
    role: "Director Comercial",
    type: "Constructora industrial",
    location: "Madrid",
    report: "Competitor Intel",
    resultBadge: "€180K en 30 días"
  },
  {
    situation: "Llevábamos 4 meses de reuniones internas debatiendo si expandirnos a legaltech. Cada semana una opinión diferente.",
    action: "Encargamos un Market Entry Brief el martes.",
    result: "El miércoles teníamos la respuesta: demanda solo en startups pre-Series A, nicho de €2.3M/año. Tomamos la decisión en 24 horas. Habíamos perdido 4 meses de debate interno.",
    name: "Marta G.",
    role: "Socia Directora",
    type: "Despacho de abogados",
    location: "Barcelona",
    report: "Market Entry Brief",
    resultBadge: "4 meses → 24 horas"
  },
  {
    situation: "Íbamos a reunirnos con un fondo de Barcelona para nuestra Serie A. No sabíamos qué términos pedían ni a qué valoraciones invertían.",
    action: "48 horas antes pedimos el Buyer Intel del fondo.",
    result: "Llegamos sabiendo sus últimas 5 inversiones, rangos de valoración y qué buscaban en founders. Negociamos sin ceder equity de más. Cerramos a €2.1M.",
    name: "Carlos M.",
    role: "CEO & Founder",
    type: "SaaS B2B",
    location: "Madrid",
    report: "Buyer Intel",
    resultBadge: "Serie A: €2.1M"
  },
  {
    situation: "Queríamos contratar 3 perfiles de growth en nuestro sector. No sabíamos qué salarios pedían, de dónde venían los mejores candidatos ni qué empresas los formaban.",
    action: "Pedimos el Talent Market Intel para el sector SaaS B2B en España.",
    result: "El reporte nos mostró que los mejores candidatos venían de 5 empresas concretas, los rangos reales eran €48-65K (habíamos presupuestado €38K), y LinkedIn no era el canal. Contratamos en 3 semanas vs los 4 meses del año anterior.",
    name: "Ana R.",
    role: "Head of People",
    type: "Scale-up fintech",
    location: "Valencia",
    report: "Talent Market Intel",
    resultBadge: "Contratación en 3 semanas"
  }
];
---

<section class="py-24 px-6 bg-gradient-to-b from-transparent via-white/[0.02] to-transparent">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Resultados <span class="text-accent">medibles</span>
      </h2>
      <p class="text-white/60 text-lg">
        No "me gustó el reporte". Resultados con euros y fechas.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-6">
      {testimonials.map((testimonial) => (
        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-8 hover:border-accent/30 transition-all duration-300">
          <!-- Situation → Action → Result format -->
          <div class="space-y-4 mb-6">
            <div>
              <span class="text-xs font-bold text-white/40 uppercase tracking-wider">Situación</span>
              <p class="text-white/70 text-sm leading-relaxed mt-1">{testimonial.situation}</p>
            </div>
            <div>
              <span class="text-xs font-bold text-accent uppercase tracking-wider">Acción</span>
              <p class="text-white/80 text-sm leading-relaxed mt-1 font-medium">{testimonial.action}</p>
            </div>
            <div>
              <span class="text-xs font-bold text-green-400 uppercase tracking-wider">Resultado</span>
              <p class="text-white/90 text-sm leading-relaxed mt-1">{testimonial.result}</p>
            </div>
          </div>
          
          <div class="flex items-center justify-between border-t border-white/10 pt-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent font-bold text-sm">
                {testimonial.name.split(' ').map(n => n[0]).join('')}
              </div>
              <div>
                <div class="text-sm font-medium text-white">{testimonial.name} · {testimonial.role}</div>
                <div class="text-xs text-white/50">
                  {testimonial.type} · {testimonial.location}
                </div>
              </div>
            </div>
            <div class="bg-green-500/10 text-green-400 text-xs font-semibold px-3 py-1.5 rounded-full border border-green-500/20">
              {testimonial.resultBadge}
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-12 text-center">
      <p class="text-white/40 text-sm">
        Nombres de empresas anonimizados por confidencialidad. Casos verificables bajo NDA.
      </p>
    </div>
  </div>
</section>
