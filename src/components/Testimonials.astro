---
const testimonials = [
  {
    quote: "Usamos el Competitor Intel para entender por qué estábamos perdiendo licitaciones. Identificamos 3 ventajas tácticas que nuestros competidores usaban y las adoptamos. En 30 días recuperamos 3 contratos que habíamos perdido.",
    type: "Empresa de construcción",
    location: "Madrid",
    report: "Competitor Intel",
    result: "3 contratos recuperados"
  },
  {
    quote: "Necesitábamos saber si valía la pena expandirnos a derecho tecnológico. El Market Entry Brief nos dio la respuesta en un día: había hueco pero con un posicionamiento muy específico. Nos ahorramos meses de análisis interno.",
    type: "Despacho de abogados",
    location: "Barcelona",
    report: "Market Entry Brief",
    result: "Decisión en 24h vs 3 meses"
  },
  {
    quote: "Antes de una reunión clave con un fondo, pedimos un Buyer Intel para entender qué buscaban exactamente y cómo habían estructurado sus últimas inversiones. Cerramos la ronda.",
    type: "Startup SaaS B2B",
    location: "Madrid",
    report: "Buyer Intel",
    result: "Ronda cerrada"
  },
  {
    quote: "Estábamos a punto de contratar a un CTO con un CV impresionante. El Talent Intel detectó inconsistencias en fechas y una demanda laboral anterior. Nos ahorramos un error costoso.",
    type: "Scale-up tecnológica",
    location: "Valencia",
    report: "Talent Intel",
    result: "Riesgo evitado"
  }
];
---

<section class="py-24 px-6 bg-gradient-to-b from-transparent via-white/[0.02] to-transparent">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Resultados <span class="text-accent">reales</span>
      </h2>
      <p class="text-white/60 text-lg">
        Casos de uso de empresas que tomaron mejores decisiones
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-6">
      {testimonials.map((testimonial) => (
        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-8 hover:border-white/20 transition-all duration-300">
          <div class="flex items-start gap-4 mb-6">
            <div class="text-accent text-3xl">"</div>
            <p class="text-white/80 text-sm leading-relaxed flex-1">
              {testimonial.quote}
            </p>
          </div>
          
          <div class="flex items-center justify-between border-t border-white/10 pt-4">
            <div>
              <div class="text-sm font-medium text-white">{testimonial.type}</div>
              <div class="text-xs text-white/50 mt-1">
                {testimonial.location} · {testimonial.report}
              </div>
            </div>
            <div class="bg-accent/10 text-accent text-xs font-semibold px-3 py-1 rounded-full">
              {testimonial.result}
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-12 text-center">
      <p class="text-white/40 text-sm">
        Nombres de empresas omitidos por confidencialidad. Resultados verificables bajo petición.
      </p>
    </div>
  </div>
</section>
