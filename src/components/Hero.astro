---
---

<section class="min-h-screen flex items-center justify-center pt-24 pb-12 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Single trust badge - only guarantee (removes fake urgency) -->
    <div class="flex justify-center mb-6">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/30 text-sm">
        <svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-green-400 font-medium">Garantía 7 días · Si no te sirve, te devolvemos el dinero</span>
      </div>
    </div>
    
    <!-- Headline - valor + porqué -->
    <h1 id="hero-headline" class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4 tracking-tight">
      Semanas de research.<br />
      <span class="text-accent">Mañana en tu inbox. Desde €19.</span>
    </h1>
    
    <p class="text-base md:text-lg text-white/60 max-w-2xl mx-auto mb-6 leading-relaxed">
      Análisis profundo de competidores, mercados o M&A — el nivel de trabajo que valdría €2.000–5.000 de tu tiempo.
    </p>
    
    <!-- CTA inmediato - reducir fricción -->
    <div class="flex flex-col items-center gap-3 mb-8">
      <a 
        href="#reportes" 
        class="inline-flex items-center justify-center gap-2 bg-accent text-dark px-10 py-5 rounded-xl text-xl font-bold hover:bg-accent/90 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-accent/25"
      >
        Ver reportes y precios →
      </a>
      <div class="flex flex-wrap justify-center gap-4 text-sm text-white/50">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Entrega en 24h
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Factura automática
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-10 h-4" viewBox="0 0 60 25" fill="currentColor">
            <path d="M59.64 14.28c0-4.96-2.4-8.88-7-8.88-4.62 0-7.42 3.92-7.42 8.84 0 5.84 3.3 8.76 8.04 8.76 2.3 0 4.04-.52 5.36-1.26v-3.88c-1.32.66-2.84 1.06-4.76 1.06-1.88 0-3.56-.66-3.78-2.96h9.52c0-.26.04-1.28.04-1.68zm-9.62-1.84c0-2.2 1.34-3.12 2.58-3.12 1.2 0 2.46.92 2.46 3.12h-5.04zM38.2 5.4c-1.88 0-3.1.88-3.78 1.5l-.24-1.2h-4.26v22.56l4.84-1.02v-5.48c.7.5 1.72 1.22 3.42 1.22 3.46 0 6.6-2.78 6.6-8.92-.02-5.58-3.2-8.66-6.58-8.66zm-1.16 13.32c-1.14 0-1.82-.4-2.28-.9v-7.12c.5-.54 1.2-.94 2.28-.94 1.74 0 2.94 1.96 2.94 4.48 0 2.58-1.18 4.48-2.94 4.48zM22.06 4.14l4.86-1.04V-.02l-4.86 1.02v3.14zM22.06 5.7h4.86v16.9h-4.86V5.7zM16.82 7.34l-.3-1.64h-4.18v16.9h4.84v-11.46c1.14-1.5 3.08-1.22 3.68-1v-4.46c-.62-.24-2.88-.68-4.04 1.66zM6.78 2.26L2.04 3.24l-.02 15.48c0 2.86 2.14 4.96 5 4.96 1.58 0 2.74-.3 3.38-.64v-3.92c-.62.26-3.68 1.16-3.68-1.74V9.56h3.68V5.7H6.72l.06-3.44z"/>
          </svg>
          <span>Pago seguro</span>
        </span>
      </div>
    </div>
    
    <!-- Testimonio FUERTE con resultado concreto -->
    <div class="bg-green-500/5 border border-green-500/20 rounded-2xl p-6 max-w-2xl mx-auto mb-8">
      <div class="flex items-start gap-4">
        <div class="bg-green-500/20 text-green-400 text-xs font-bold px-3 py-1.5 rounded-full whitespace-nowrap">
          €180K en 30 días
        </div>
        <div class="text-left">
          <p class="text-white/80 text-sm leading-relaxed mb-2">
            "Descubrimos que nuestro competidor incluía 3 años de postventa en sus ofertas. Añadimos lo mismo, <strong class="text-white">ganamos las 2 siguientes licitaciones</strong>."
          </p>
          <p class="text-xs text-white/50">— Director Comercial, Constructora industrial · Competitor Intel €35</p>
        </div>
      </div>
    </div>
    
    <!-- Ver ejemplo - prominente -->
    <div class="mb-10">
      <a href="#ejemplo" class="inline-flex items-center gap-2 border-2 border-accent/40 text-accent px-6 py-3 rounded-xl text-sm font-medium hover:bg-accent/10 transition-all">
        👁️ Ver ejemplo REAL de reporte (22 páginas) — esto es lo que recibes
      </a>
    </div>
    
    <!-- Trust metrics - más compacto -->
    <div class="grid grid-cols-4 gap-4 text-center border-t border-white/10 pt-8 max-w-2xl mx-auto">
      <div>
        <div class="text-2xl font-bold text-accent">24h</div>
        <div class="text-xs text-white/50 mt-1">Entrega</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white">€19</div>
        <div class="text-xs text-white/50 mt-1">Desde</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-accent">22</div>
        <div class="text-xs text-white/50 mt-1">Páginas</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white">100%</div>
        <div class="text-xs text-white/50 mt-1">Garantía</div>
      </div>
    </div>
  </div>
</section>


