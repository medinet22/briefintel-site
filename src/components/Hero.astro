---
---

<section class="min-h-screen flex items-center justify-center pt-28 pb-16 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Trust badge with guarantee + urgency -->
    <div class="flex flex-wrap justify-center gap-3 mb-8">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-amber-500/10 border border-amber-500/30 text-sm">
        <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span>
        <span class="text-amber-400 font-medium">Solo 3 pedidos/día</span>
      </div>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/30 text-sm">
        <svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-green-400 font-medium">Garantía 7 días</span>
      </div>
    </div>
    
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6 tracking-tight">
      Inteligencia de negocio<br />
      <span class="text-accent">para decidir mejor, más rápido y con evidencia.</span>
    </h1>
    
    <p class="text-lg md:text-xl text-white/70 max-w-3xl mx-auto mb-2 leading-relaxed">
      Informes de inteligencia competitiva, de mercado, de talento y de M&A, en 24h. <strong class="text-white/80">Desde €19.</strong>
    </p>
    <p class="text-sm text-white/40 mb-4">
      <span class="line-through">Consultoras: €5.000–15.000</span> · <span class="text-accent">Tú: €19–119</span>
    </p>
    
    <p class="text-md text-white/50 max-w-2xl mx-auto mb-4">
      Competidores, mercado, talento o potenciales compradores — analizamos lo que necesitas para tomar la decisión que llevas semanas posponiendo.
    </p>
    
    <!-- Who is this for -->
    <p class="text-sm text-accent/80 mb-8 max-w-lg mx-auto">
      Para founders, directores y equipos de estrategia que necesitan decidir rápido y bien.
    </p>
    
    <!-- Single dominant CTA -->
    <div class="flex flex-col items-center gap-4 mb-6">
      <a 
        href="#reportes" 
        class="inline-flex items-center justify-center gap-2 bg-accent text-dark px-10 py-5 rounded-xl text-xl font-bold hover:bg-accent/90 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-accent/25"
      >
        Elegir mi reporte
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href="#ejemplo" class="text-white/70 text-sm hover:text-white underline">Ver ejemplo de reporte</a>
      <span class="text-sm text-white/40">Pack Estratégico €119 (ahorra €43) · Individuales desde €19</span>
    </div>

    <!-- Trust badges debajo CTA -->
    <div class="flex flex-wrap justify-center gap-4 text-sm text-white/50 mb-10">
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
        Sin suscripción
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
        Factura automática
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
        Entrega en 24h
      </span>
    </div>
    
    <!-- Real testimonial from actual customer -->
    <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6 max-w-2xl mx-auto mb-12">
      <div class="flex items-center justify-center gap-1 mb-3">
        <span class="text-amber-400">★★★★★</span>
        <span class="text-white/50 text-sm ml-2">5/5</span>
      </div>
      <p class="text-white/80 text-sm leading-relaxed mb-4 italic">
        "Bastante útil. El análisis de competidores nos dio visibilidad sobre movimientos que no teníamos en el radar."
      </p>
      <div class="flex items-center justify-center gap-3">
        <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent font-bold">S</div>
        <div class="text-left">
          <p class="text-sm font-medium text-white/90">Seegman</p>
          <p class="text-xs text-white/50">Competitor Intel · €35</p>
        </div>
      </div>
    </div>
    
    <!-- Trust metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center border-t border-white/10 pt-10">
      <div>
        <div class="text-3xl font-bold text-accent">24h</div>
        <div class="text-sm text-white/50 mt-1">Entrega garantizada</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-white">€19-119</div>
        <div class="text-sm text-white/50 mt-1">Precio fijo transparente</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-accent">4.7/5</div>
        <div class="text-sm text-white/50 mt-1">Valoración clientes</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-white">100%</div>
        <div class="text-sm text-white/50 mt-1">Garantía devolución</div>
      </div>
    </div>
  </div>
</section>
