---
const methodologySteps = [
  {
    title: 'Fuentes primarias verificadas',
    description: 'LinkedIn, Glassdoor, Crunchbase, Registro Mercantil, SABI, patentes EUIPO, job postings y 40+ fuentes más.',
  },
  {
    title: 'Señales en tiempo real',
    description: 'No datos de hace 6 meses. Job postings activos, cambios de precio de esta semana, contrataciones de este mes.',
  },
  {
    title: 'Triangulación obligatoria',
    description: 'Cada insight verificado con 2+ fuentes independientes. Si no podemos confirmarlo, lo etiquetamos como "señal temprana".',
  },
  {
    title: 'Niveles de confianza explícitos',
    description: 'CONFIRMADO (2+ fuentes), INFERIDO (1 fuente + contexto), SEÑAL TEMPRANA (indicios). Siempre sabes cuánto confiar.',
  },
];

const trustBadges = [
  { icon: "🔒", label: "Pago seguro con Stripe" },
  { icon: "📄", label: "Factura automática" },
  { icon: "↩️", label: "Garantía 7 días" },
  { icon: "🕐", label: "Entrega en 24h" },
];

const qualityChecks = [
  "¿Hay un insight que el cliente no podría haber encontrado solo?",
  "¿Cada dato tiene interpretación y acción concreta?",
  "¿Las acciones dicen 'haz esto' y no 'considera esto'?",
  "¿Cada claim tiene fuente citada y verificable?",
  "¿Los datos son frescos (<30 días)?",
  "¿El plan de acción es ejecutable en 30 días?"
];
---

<section class="py-24 bg-gradient-to-b from-transparent via-white/[0.02] to-transparent relative">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Content -->
      <div>
        <span class="inline-block text-accent text-xs font-bold uppercase tracking-wider mb-4">Metodología</span>
        <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-6">
          No es magia.<br />
          <span class="text-accent">Es proceso riguroso.</span>
        </h2>
        <p class="text-white/60 text-lg mb-8 leading-relaxed">
          Fuentes verificadas y metodología de consultoría estratégica, sin los €50.000 de un proyecto tradicional. 
          La diferencia: automatización inteligente + revisión humana experta.
        </p>
        
        <!-- Methodology steps -->
        <div class="space-y-6">
          {methodologySteps.map((step, index) => (
            <div class="flex gap-4">
              <div class="w-8 h-8 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <span class="text-accent font-bold text-sm">{index + 1}</span>
              </div>
              <div>
                <h4 class="font-bold mb-1 text-white/90">{step.title}</h4>
                <p class="text-white/50 text-sm">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Right: Quality badge + Trust signals -->
      <div class="space-y-6">
        <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-8">
          <div class="text-center mb-8">
            <div class="w-20 h-20 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <h3 class="text-2xl font-black mb-2">Checklist de calidad</h3>
            <p class="text-white/50">Cada reporte pasa estos 6 controles antes de enviarse:</p>
          </div>
          
          <div class="space-y-3">
            {qualityChecks.map((check) => (
              <div class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-white/70">{check}</span>
              </div>
            ))}
          </div>
        </div>
        
        <!-- Trust badges -->
        <div class="grid grid-cols-2 gap-4">
          {trustBadges.map((badge) => (
            <div class="bg-white/[0.02] border border-white/10 rounded-xl p-4 flex items-center gap-3">
              <span class="text-xl">{badge.icon}</span>
              <span class="text-sm text-white/70">{badge.label}</span>
            </div>
          ))}
        </div>
        
        <!-- Who's behind -->
        <div class="bg-accent/5 border border-accent/20 rounded-xl p-6">
          <h4 class="font-semibold mb-3 text-white/90">¿Quién hay detrás?</h4>
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center text-accent font-bold flex-shrink-0">BI</div>
            <div>
              <p class="text-sm font-medium text-white/90">Equipo BriefIntel</p>
              <p class="text-xs text-white/50">+15 años en estrategia e inteligencia competitiva · Experiencia Big-4 · Ex-consultoría estratégica</p>
            </div>
          </div>
          <p class="text-sm text-white/60 leading-relaxed">
            Red de analistas con experiencia en Big-4, M&A y estrategia corporativa.
            Metodología de proyectos enterprise, ahora accesible para cualquier empresa.
          </p>
        </div>
        
        <!-- Data sources -->
        <div class="bg-white/[0.02] border border-white/10 rounded-xl p-6">
          <h4 class="font-semibold mb-3 text-white/90">Fuentes que usamos</h4>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 rounded-full bg-white/5 text-xs text-white/60 border border-white/10">LinkedIn</span>
            <span class="px-3 py-1 rounded-full bg-white/5 text-xs text-white/60 border border-white/10">Crunchbase</span>
            <span class="px-3 py-1 rounded-full bg-white/5 text-xs text-white/60 border border-white/10">Glassdoor</span>
            <span class="px-3 py-1 rounded-full bg-white/5 text-xs text-white/60 border border-white/10">Registro Mercantil</span>
            <span class="px-3 py-1 rounded-full bg-white/5 text-xs text-white/60 border border-white/10">SABI</span>
            <span class="px-3 py-1 rounded-full bg-white/5 text-xs text-white/60 border border-white/10">Google Ads Library</span>
            <span class="px-3 py-1 rounded-full bg-white/5 text-xs text-white/60 border border-white/10">Patentes EUIPO</span>
            <span class="px-3 py-1 rounded-full bg-white/5 text-xs text-white/60 border border-white/10">+35 más</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
