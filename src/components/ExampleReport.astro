<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Qué incluye <span class="text-accent">un reporte</span>
      </h2>
      <p class="text-white/60 text-lg">
        Entre 12 y 25 páginas de insights accionables
      </p>
    </div>
    
    <div class="bg-white/[0.02] border border-white/10 rounded-2xl overflow-hidden">
      <div class="bg-white/[0.02] border-b border-white/10 px-8 py-4 flex items-center gap-3">
        <div class="flex gap-2">
          <div class="w-3 h-3 rounded-full bg-white/20"></div>
          <div class="w-3 h-3 rounded-full bg-white/20"></div>
          <div class="w-3 h-3 rounded-full bg-white/20"></div>
        </div>
        <span class="text-sm text-white/40 font-mono">competitor-intel-acme-corp.pdf</span>
      </div>
      
      <div class="p-8 md:p-12 space-y-8">
        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
                <span class="text-accent text-lg">📋</span>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Resumen Ejecutivo</h4>
                <p class="text-sm text-white/50">Los 5 hallazgos clave en 1 página. Para decisores con poco tiempo.</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
                <span class="text-accent text-lg">🔍</span>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Análisis en Profundidad</h4>
                <p class="text-sm text-white/50">Cada área crítica desglosada con datos, contexto y implicaciones.</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
                <span class="text-accent text-lg">💡</span>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Insights Priorizados</h4>
                <p class="text-sm text-white/50">Qué importa más, ordenado por impacto y urgencia.</p>
              </div>
            </div>
          </div>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
                <span class="text-accent text-lg">📡</span>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Señales Débiles</h4>
                <p class="text-sm text-white/50">Indicadores tempranos que pueden convertirse en tendencias.</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
                <span class="text-accent text-lg">✅</span>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Plan de Acción 30 días</h4>
                <p class="text-sm text-white/50">Pasos concretos para actuar sobre los insights. No solo información, sino dirección.</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
                <span class="text-accent text-lg">📊</span>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Nivel de Confianza</h4>
                <p class="text-sm text-white/50">Cada insight marcado: CONFIRMADO, INFERIDO o SEÑAL DÉBIL.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
