---
const steps = [
  {
    number: "01",
    title: "Elige tu reporte y paga",
    description: "Checkout seguro con Stripe en menos de 1 minuto. Factura automática. Precio fijo, sin sorpresas.",
    icon: "💳",
    detail: "Pago único · Sin suscripción · Factura automática"
  },
  {
    number: "02",
    title: "Rellena tu brief (5 min)",
    description: "Te redirigimos a un formulario donde nos dices: tu web, el sujeto a analizar, la decisión que necesitas tomar y tus 3 preguntas clave. Puedes adjuntar archivos.",
    icon: "📋",
    detail: "Web · Archivos · 3 preguntas clave · Decisión objetivo"
  },
  {
    number: "03",
    title: "Investigamos en profundidad",
    description: "Investigamos tu sector en profundidad: competidores, mercado, talento o compradores potenciales. Sin plantillas — cada reporte es específico para tu empresa y tu decisión.",
    icon: "🔍",
    detail: "40+ fuentes verificadas · Investigación ad-hoc"
  },
  {
    number: "04",
    title: "Recibes tu reporte en 24h",
    description: "PDF ejecutivo de 12-25 páginas con resumen, insights priorizados, nivel de confianza por dato y plan de acción de 30 días. Listo para tomar decisiones.",
    icon: "📊",
    detail: "PDF ejecutivo · Fuentes citadas · Plan de acción 30 días"
  }
];

const methodology = [
  {
    icon: "🤖",
    title: "IA entrenada en miles de casos",
    description: "No es un chatbot genérico. IA entrenada específicamente en inteligencia competitiva y análisis de mercados con miles de informes reales."
  },
  {
    icon: "👨‍💼",
    title: "Analistas con +15 años de experiencia",
    description: "Analistas senior con experiencia en consultoría estratégica, Big-4 y M&A revisan y validan cada reporte antes de enviarlo. Siempre hay un humano detrás."
  },
  {
    icon: "📡",
    title: "40+ fuentes verificadas en tiempo real",
    description: "Registros oficiales, LinkedIn, prensa sectorial, bases de datos premium, señales digitales y datos de mercado actualizados."
  },
  {
    icon: "✅",
    title: "22 puntos de control de calidad",
    description: "Metodología propietaria: cada dato triangulado, cada insight con nivel de confianza (CONFIRMADO / INFERIDO / SEÑAL EMERGENTE), cada acción concreta."
  }
];
---

<section id="como-funciona" class="py-24 px-6 bg-gradient-to-b from-transparent via-white/[0.02] to-transparent">
  <div class="max-w-6xl mx-auto">
    <!-- Steps -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        De tu pregunta a <span class="text-accent">decisión informada</span>
      </h2>
      <p class="text-white/60 text-lg">
        Cuatro pasos. 24 horas. Cero ambigüedad.
      </p>
    </div>

    <div class="grid md:grid-cols-4 gap-6 mb-6">
      {steps.map((step, index) => (
        <div class="relative group">
          <div class="bg-white/[0.02] border border-white/10 rounded-2xl p-6 h-full hover:border-accent/30 transition-all duration-300 hover:bg-white/[0.04]">
            <div class="text-3xl mb-4">{step.icon}</div>
            <div class="text-accent text-xs font-mono font-bold mb-2">{step.number}</div>
            <h3 class="text-base font-bold mb-2 leading-tight">{step.title}</h3>
            <p class="text-white/50 text-xs leading-relaxed mb-3">{step.description}</p>
            <div class="text-xs text-accent/60 border-t border-white/5 pt-3 leading-relaxed">{step.detail}</div>
          </div>
          {index < steps.length - 1 && (
            <div class="hidden md:flex absolute top-8 -right-3 z-10 w-6 h-6 bg-dark border border-white/10 rounded-full items-center justify-center">
              <svg class="w-3 h-3 text-accent/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Brief highlight -->
    <div class="bg-accent/5 border border-accent/20 rounded-2xl p-6 mb-20 flex flex-col md:flex-row items-center gap-6">
      <div class="text-4xl">📋</div>
      <div class="flex-1">
        <h3 class="font-bold text-white mb-1">El brief es la clave del reporte</h3>
        <p class="text-white/60 text-sm">Después de pagar, te pedimos: <strong class="text-white/80">tu web</strong>, tu <strong class="text-white/80">sector</strong> y tus <strong class="text-white/80">preguntas clave</strong> (opcional). Puedes adjuntar archivos (PDFs, Excel) hasta 10MB. Nosotros identificamos los competidores, mercados o perfiles relevantes. Cuanto más contexto des, más accionable será el reporte.</p>
      </div>
      <a href="#reportes" class="bg-accent text-dark px-6 py-3 rounded-xl font-bold text-sm hover:bg-accent/90 transition-colors whitespace-nowrap flex-shrink-0">
        Elegir reporte →
      </a>
    </div>

    <!-- Methodology -->
    <div class="border-t border-white/10 pt-20">
      <div class="text-center mb-12">
        <span class="inline-block text-accent text-xs font-bold uppercase tracking-wider mb-4">Por qué funciona</span>
        <h3 class="text-2xl md:text-3xl font-bold mb-4">
          No es un chatbot. No es Google.
        </h3>
        <p class="text-white/60 text-lg max-w-2xl mx-auto">
          BriefIntel combina tecnología propietaria con experiencia humana real.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {methodology.map((item) => (
          <div class="bg-white/[0.02] border border-white/10 rounded-xl p-6 hover:border-accent/30 transition-all duration-300">
            <div class="text-3xl mb-4">{item.icon}</div>
            <h4 class="font-semibold mb-2 text-white/90 text-sm">{item.title}</h4>
            <p class="text-xs text-white/50 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
